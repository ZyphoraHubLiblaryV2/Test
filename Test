        Parent = BarBg,
    })
    Utility.Corner(BarFill, 999)
    Utility.Tween(BarFill, TweenInfo.new(1.2, EASE, DIR), {Size = UDim2.new(1, 0, 1, 0)})

    task.delay(config.Duration or 1.4, function()
        local tw = Utility.Tween(Frame, TweenInfo.new(0.4, EASE, DIR), {BackgroundTransparency = 1})
        Utility.Tween(Title, TweenInfo.new(0.3), {TextTransparency = 1})
        tw.Completed:Connect(function()
            ScreenGui:Destroy()
        end)
    end)
end

return NevoraHub
