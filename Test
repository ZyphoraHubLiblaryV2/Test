function NotificationSystem:Notify(options)
    options = options or {}
    local title = options.Title or "Notification"
    local message = options.Message or ""
    local notifType = options.Type or "Info"
    local duration = options.Duration or 4
    local icon = options.Icon
    local progress = options.Progress ~= false

    if #self.Active >= self.MaxActive then
        table.insert(self.Queue, options)
        return
    end

    local typeColors = {
        Info = Constants.Accent,
        Success = Constants.Success,
        Warning = Constants.Warning,
        Error = Constants.Error,
    }
    local color = typeColors[notifType] or Constants.Accent

    local notif = Utility.Create("Frame", {
        Name = "Notification",
        Size = UDim2.new(0, 360, 0, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = self.Container,
    })

    local glass = Utility.CreateGlass(notif, 0.15)
    glass.Name = "Glass"

    local accentBar = Utility.Create("Frame", {
        Name = "AccentBar",
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Parent = glass,
    })

    local accentCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = accentBar,
    })

    local content = Utility.Create("Frame", {
        Name = "Content",
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 15, 0, 10),
        BackgroundTransparency = 1,
        Parent = glass,
    })

    local iconLabel = Utility.Create("ImageLabel", {
        Name = "Icon",
        Size = UDim2.new(0, 20, 0, 20),
        BackgroundTransparency = 1,
        Image = icon or IconSystem:GetIcon(notifType == "Success" and "Check" or notifType == "Error" and "X" or notifType == "Warning" and "AlertTriangle" or "Info"),
        ImageColor3 = color,
        Parent = content,
    })

    local titleLabel = Utility.Create("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, -30, 0, 20),
        Position = UDim2.new(0, 28, 0, 0),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Constants.TextPrimary,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = content,
    })

    local messageLabel = Utility.Create("TextLabel", {
        Name = "Message",
        Size = UDim2.new(1, -30, 0, 0),
        Position = UDim2.new(0, 28, 0, 22),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = Constants.TextSecondary,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = content,
    })

    local closeBtn = Utility.Create("TextButton", {
        Name = "Close",
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -20, 0, 0),
        BackgroundTransparency = 1,
        Text = "✕",
        TextColor3 = Constants.TextSecondary,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        Parent = content,
    })

    local progressBar
    if progress then
        progressBar = Utility.Create("Frame", {
            Name = "ProgressBar",
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = color,
            BackgroundTransparency = 0.3,
            BorderSizePixel = 0,
            Parent = glass,
        })

        local progressCorner = Utility.Create("UICorner", {
            CornerRadius = UDim.new(0, 1),
            Parent = progressBar,
        })
    end

    local textHeight = TextService:GetTextSize(
        message, 12, Enum.Font.Gotham,
        Vector2.new(310, math.huge)
    ).Y
    local totalHeight = math.max(60, 40 + textHeight)

    notif.Size = UDim2.new(0, 360, 0, 0)
    Utility.Tween(notif, Constants.TweenInfo.Smooth, {
        Size = UDim2.new(0, 360, 0, totalHeight)
    })

    if progressBar then
        progressBar.Size = UDim2.new(1, 0, 0, 2)
        Utility.Tween(progressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 2)
        })
    end

    local function dismiss()
        Utility.Tween(notif, Constants.TweenInfo.Fast, {
            Size = UDim2.new(0, 360, 0, 0),
            BackgroundTransparency = 1,
        }, function()
            notif:Destroy()
            for i, n in ipairs(self.Active) do
                if n == notif then
                    table.remove(self.Active, i)
                    break
                end
            end
            if #self.Queue > 0 then
                local nextNotif = table.remove(self.Queue, 1)
                self:Notify(nextNotif)
            end
        end)
    end

    closeBtn.MouseButton1Click:Connect(dismiss)
    task.delay(duration, dismiss)
    table.insert(self.Active, notif)

    return notif
end

function NotificationSystem:Success(title, message, duration)
    return self:Notify({
        Title = title,
        Message = message,
        Type = "Success",
        Duration = duration,
    })
end

function NotificationSystem:Error(title, message, duration)
