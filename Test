Modules.Window = (function()
    local Window = {}
    Window.__index = Window
    
    function Window.new(config, mainLib)
        local self = setmetatable({}, Window)
        self.MainLib = mainLib
        self.Tabs = {}
        self.Connections = {}
        
        local baseGui = Modules.Utilities:CreateInstance("ScreenGui", CoreGui, "NevoraHubUI", {
            ResetOnSpawn = false
        })
        
        local mainFrame = Modules.Utilities:CreateInstance("Frame", baseGui, "MainWindow", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = config.Size or UDim2.new(0, 650, 0, 420),
            BackgroundColor3 = mainLib.Theme.Background,
            BorderSizePixel = 0,
            ClipsDescendants = true
        })
        
        local uiScale = Modules.Utilities:CreateInstance("UIScale", mainFrame, "Scale")
        local function autoScale()
            local viewportSize = workspace.CurrentCamera.ViewportSize
            if viewportSize.X < 768 then
                uiScale.Scale = math.clamp(viewportSize.X / 700, 0.75, 0.95)
            else
                uiScale.Scale = 1
            end
        end
        autoScale()
        mainLib.Utilities:TrackConnection(self.Connections, workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(autoScale))
        
        Modules.Utilities:CreateInstance("UIStroke", mainFrame, "Stroke", { Color = mainLib.Theme.Border, Thickness = 1 })
        Modules.Utilities:CreateInstance("UICorner", mainFrame, "Corner", { CornerRadius = config.CornerRadius or UDim.new(0, 12) })
        
        local header = Modules.Utilities:CreateInstance("Frame", mainFrame, "HeaderFrame", {
            Size = UDim2.new(1, 0, 0, 50),
            BackgroundTransparency = 1
        })
        
        Modules.Utilities:CreateInstance("TextLabel", header, "Title", {
            Size = UDim2.new(0, 200, 1, 0),
            Position = UDim2.new(0, 20, 0, 0),
            Text = config.Title or "Nevora Hub",
            TextColor3 = mainLib.Theme.Text,
            Font = Enum.Font.GothamBold,
            TextSize = 18,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1
        })
        
        local tabContainer = Modules.Utilities:CreateInstance("ScrollingFrame", mainFrame, "TabNavigation", {
            Size = UDim2.new(0, 160, 1, -60),
            Position = UDim2.new(0, 10, 0, 55),
            BackgroundTransparency = 1,
            ScrollBarThickness = 0
        })
        Modules.Utilities:CreateInstance("UIListLayout", tabContainer, "Layout", { Padding = UDim.new(0, 6) })
        
        local containerHolder = Modules.Utilities:CreateInstance("Frame", mainFrame, "ContentContainer", {
            Size = UDim2.new(1, -190, 1, -65),
            Position = UDim2.new(0, 180, 0, 55),
            BackgroundTransparency = 1
        })
        
        self.MainFrame = mainFrame
        self.TabContainer = tabContainer
        self.ContainerHolder = containerHolder
        
        mainLib.Utilities:MakeDraggable(mainFrame, 0.12)
        mainLib.Animations:ScaleIn(mainFrame, 0.25)
        self:SetCloseButton({}, mainFrame)
        
        return self
    end
    
    function Window:CreateTab(name, iconId)
        local tab = Modules.Tabs.new(name, iconId, self)
        table.insert(self.Tabs, tab)
        return tab
    end
    
    function Window:SetCloseButton(config, mainFrame)
        local closeBtn = Modules.Utilities:CreateInstance("ImageButton", mainFrame.HeaderFrame, "CloseBtn", {
            Size = UDim2.new(0, 32, 0, 32),
            Position = UDim2.new(1, -42, 0, 9),
            BackgroundTransparency = 1,
            Image = config.Image or "rbxassetid://9886659671",
            ImageColor3 = self.MainLib.Theme.SecondaryText
        })
        
        closeBtn.MouseEnter:Connect(function()
            TweenService:Create(closeBtn, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(231, 76, 60), Rotation = 90}):Play()
        end)
        closeBtn.MouseLeave:Connect(function()
            TweenService:Create(closeBtn, TweenInfo.new(0.2), {ImageColor3 = self.MainLib.Theme.SecondaryText, Rotation = 0}):Play()
        end)
        closeBtn.MouseButton1Click:Connect(function()
            self.MainLib.Animations:ScaleOut(mainFrame, 0.25, function()
                self.MainLib:Destroy()
            end)
        end)
    end
    
    function Window:Destroy()
        for _, conn in ipairs(self.Connections) do if conn then conn:Disconnect() end end
        if self.MainFrame then self.MainFrame.Parent:Destroy() end
    end
    
    return Window
end)()

-- ==========================================
-- 8. GLOBAL NEVORA HUB API INTEGRATION
-- ==========================================
function NevoraHub:CreateWindow(config)
    config = config or {}
    local window = Modules.Window.new(config, self)
    table.insert(self.CreatedWindows, window)
    return window
end

function NevoraHub:SetBackground(config)
    Modules.Background:ApplyGlobal(config, self.CreatedWindows[1], self)
end

function NevoraHub:Notification(config)
    return Modules.Notifications.new(config, self)
end

function NevoraHub:Destroy()
    for _, conn in ipairs(self.Connections) do if conn then conn:Disconnect() end end
    for _, win in ipairs(self.CreatedWindows) do win:Destroy() end
    local ui = CoreGui:FindFirstChild("NevoraHubUI")
    if ui then ui:Destroy() end
end

-- Bridge global variable agar modul internal mengenali utilitas pembantu
NevoraHub.Utilities = Modules.Utilities
NevoraHub.Animations = Modules.Animations

return NevoraHub
