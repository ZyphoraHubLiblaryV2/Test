        end
    end)

    return keyGui
end

-- NevoraHub Main Functions
function NevoraHub:CreateWindow(config)
    return Window.new(config)
end

function NevoraHub:SetTheme(themeName)
    if Themes[themeName] then
        self.CurrentTheme = Themes[themeName]
    end
end

function NevoraHub:GetThemes()
    local themeList = {}
    for name, _ in pairs(Themes) do
        table.insert(themeList, name)
    end
    return themeList
end

function NevoraHub:CreateTheme(name, colors)
    Themes[name] = colors
end

-- Return the library
return NevoraHub
