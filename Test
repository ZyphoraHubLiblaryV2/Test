        self.IsBinding = true
        self.BindButton.Text = "..."
        Utility:Tween(self.BindButton, { BackgroundColor3 = Nevora.Theme.Hover }, 0.2)
    end)
    
    GlobalConnections:Add("KeybindInput_" .. config.Name, UserInputService.InputBegan:Connect(function(input, processed)
        if self.IsBinding then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                local blacklisted = {
                    Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
                    Enum.KeyCode.Space, Enum.KeyCode.Escape, Enum.KeyCode.Tab, Enum.KeyCode.Backspace
                }
                if not table.find(blacklisted, input.KeyCode) then
                    self.Key = input.KeyCode
                    self.BindButton.Text = self.Key.Name
                else
                    self.BindButton.Text = "None"
                    self.Key = Enum.KeyCode.Unknown
                end
            end
            
            self.IsBinding = false
            Utility:Tween(self.BindButton, { BackgroundColor3 = Nevora.Theme.Background }, 0.2)
            
        elseif not processed and input.KeyCode == self.Key and self.Key ~= Enum.KeyCode.Unknown then
            self.Callback()
        end
    end))
    
    return self
end

