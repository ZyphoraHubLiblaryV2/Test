        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn
    })

    -- Page
    local page = Create("ScrollingFrame", {
        Size = UDim2.new(1, -16, 1, -16),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = self.PageContainer
    })

    local pageLayout = Create("UIListLayout", {
        Padding = UDim.new(0, 8),
        Parent = page
    })

    Create("UIPadding", {
        PaddingTop = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 4),
        Parent = page
    })

    local tabData = {
        Name = tabName,
        Button = tabBtn,
        Label = tabLabel,
        Page = page,
        Layout = pageLayout,
        Elements = {},
        Index = self.TabCount
    }

    table.insert(self.Tabs, tabData)

    -- Tab click handler
    tabBtn.MouseButton1Click:Connect(function()
        self:SelectTab(self.TabCount)
    end)

    -- Hover effects
    tabBtn.MouseEnter:Connect(function()
        if self.CurrentTab ~= self.TabCount then
            Tween(tabBtn, 0.2, {BackgroundColor3 = theme.BackgroundTertiary}):Play()
        end
    end)

    tabBtn.MouseLeave:Connect(function()
        if self.CurrentTab ~= self.TabCount then
            Tween(tabBtn, 0.2, {BackgroundColor3 = theme.BackgroundSecondary}):Play()
        end
    end)

    -- Auto select first tab
    if self.TabCount == 1 then
        self:SelectTab(1)
    end

    return tabData
end

function Window:SelectTab(index)
    local theme = NevoraHub.CurrentTheme

    for i, tab in ipairs(self.Tabs) do
        if i == index then
            tab.Page.Visible = true
            Tween(tab.Button, 0.2, {BackgroundColor3 = theme.BackgroundTertiary}):Play()
            tab.Label.TextColor3 = theme.Text
            tab.Label.Font = Enum.Font.GothamBold

            -- Move highlight
            Tween(self.TabHighlight, 0.2, {
                Position = UDim2.new(0, 0, 0, tab.Button.AbsolutePosition.Y - self.TabContainer.AbsolutePosition.Y + 4)
            }):Play()
        else
            tab.Page.Visible = false
            Tween(tab.Button, 0.2, {BackgroundColor3 = theme.BackgroundSecondary}):Play()
            tab.Label.TextColor3 = theme.TextSecondary
            tab.Label.Font = Enum.Font.GothamMedium
        end
    end

    self.CurrentTab = index
end

function Window:Destroy()
    Tween(self.Main, 0.3, {Size = UDim2.new(0, self.Main.Size.X.Offset, 0, 0)}):Play()
    task.wait(0.3)
    self.ScreenGui:Destroy()
end

