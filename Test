function Section:CreateFPSCounter(options)
    options = options or {}
    local fps = {}
    fps.CurrentFPS = 0
    fps.AverageFPS = 0
    fps.MinFPS = math.huge
    fps.MaxFPS = 0
    fps.Samples = {}
    fps.MaxSamples = options.MaxSamples or 60

    local fpsFrame = Utility.Create("Frame", {
        Name = options.Name or "FPSCounter",
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = Constants.Card,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        Parent = self.ComponentContainer,
    })

    local fpsCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = fpsFrame,
    })

    local fpsLabel = Utility.Create("TextLabel", {
        Name = "FPS",
        Size = UDim2.new(0.5, 0, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = "60 FPS",
        TextColor3 = Constants.Success,
        TextSize = 20,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = fpsFrame,
    })

    local details = Utility.Create("TextLabel", {
        Name = "Details",
        Size = UDim2.new(0.5, -12, 0, 20),
        Position = UDim2.new(0.5, 0, 0.5, -10),
        BackgroundTransparency = 1,
        Text = "Avg: 60 | Min: 60 | Max: 60",
        TextColor3 = Constants.TextSecondary,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = fpsFrame,
    })

    local lastUpdate = tick()
    local frameCount = 0

    local connection = RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
        local now = tick()

        if now - lastUpdate >= 1 then
            fps.CurrentFPS = frameCount
            table.insert(fps.Samples, frameCount)

            if #fps.Samples > fps.MaxSamples then
                table.remove(fps.Samples, 1)
            end

            local total = 0
            fps.MinFPS = math.huge
            fps.MaxFPS = 0
            for _, sample in ipairs(fps.Samples) do
                total = total + sample
                fps.MinFPS = math.min(fps.MinFPS, sample)
                fps.MaxFPS = math.max(fps.MaxFPS, sample)
            end
            fps.AverageFPS = math.floor(total / #fps.Samples)

            fpsLabel.Text = fps.CurrentFPS .. " FPS"
            details.Text = string.format("Avg: %d | Min: %d | Max: %d", fps.AverageFPS, fps.MinFPS, fps.MaxFPS)

            if fps.CurrentFPS >= 55 then
                fpsLabel.TextColor3 = Constants.Success
            elseif fps.CurrentFPS >= 30 then
                fpsLabel.TextColor3 = Constants.Warning
            else
                fpsLabel.TextColor3 = Constants.Error
            end

            frameCount = 0
            lastUpdate = now
        end
    end)

    fps.Instance = fpsFrame
    fps.Stop = function()
        connection:Disconnect()
    end

    table.insert(self.Components, fps)
    return fps
end

