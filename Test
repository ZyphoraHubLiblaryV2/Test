-- BUTTON
function NevoraHub:CreateButton(Config)
    local ButtonFrame = Instance.new("TextButton")
    ButtonFrame.Parent = self.Container
    ButtonFrame.BackgroundColor3 = Theme.Panel
    ButtonFrame.Size = UDim2.new(1, 0, 0, 40)
    ButtonFrame.Text = ""
    ButtonFrame.AutoButtonColor = false
    Instance.new("UICorner", ButtonFrame).CornerRadius = UDim.new(0, 6)
    
    Instance.new("UIStroke", ButtonFrame).Color = Theme.Border
    Instance.new("UIStroke", ButtonFrame).Thickness = 1

    local Label = Instance.new("TextLabel")
    Label.Parent = ButtonFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.Size = UDim2.new(1, -30, 1, 0)
    Label.Font = Enum.Font.GothamMedium
    Label.Text = Config.Name or "Button"
    Label.TextColor3 = Theme.TextPrimary
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Animasi Interaksi
    ButtonFrame.MouseEnter:Connect(function()
        CreateTween(ButtonFrame, {0.2}, {BackgroundColor3 = Color3.fromRGB(30, 30, 35)})
    end)
    ButtonFrame.MouseLeave:Connect(function()
        CreateTween(ButtonFrame, {0.2}, {BackgroundColor3 = Theme.Panel})
    end)
    ButtonFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            CreateTween(ButtonFrame, {0.1}, {Size = UDim2.new(1, -4, 0, 36), BackgroundColor3 = self.Library.Accent})
            CreateTween(Label, {0.1}, {TextColor3 = Theme.Background})
        end
    end)
    ButtonFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            CreateTween(ButtonFrame, {0.2}, {Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Color3.fromRGB(30, 30, 35)})
            CreateTween(Label, {0.2}, {TextColor3 = Theme.TextPrimary})
            if Config.Callback then
                task.spawn(Config.Callback)
            end
        end
    end)
end

-- TOGGLE
function NevoraHub:CreateToggle(Config)
    local State = Config.Default or false
    
    local ToggleFrame = Instance.new("TextButton")
    ToggleFrame.Parent = self.Container
    ToggleFrame.BackgroundColor3 = Theme.Panel
    ToggleFrame.Size = UDim2.new(1, 0, 0, 40)
    ToggleFrame.Text = ""
    ToggleFrame.AutoButtonColor = false
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)
    
    local Label = Instance.new("TextLabel")
    Label.Parent = ToggleFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Font = Enum.Font.GothamMedium
    Label.Text = Config.Name or "Toggle"
    Label.TextColor3 = Theme.TextPrimary
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local SwitchBg = Instance.new("Frame")
    SwitchBg.Parent = ToggleFrame
    SwitchBg.BackgroundColor3 = State and self.Library.Accent or Theme.Border
    SwitchBg.AnchorPoint = Vector2.new(1, 0.5)
    SwitchBg.Position = UDim2.new(1, -15, 0.5, 0)
    SwitchBg.Size = UDim2.new(0, 40, 0, 20)
    Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)
    
    local SwitchCircle = Instance.new("Frame")
    SwitchCircle.Parent = SwitchBg
    SwitchCircle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SwitchCircle.AnchorPoint = Vector2.new(0, 0.5)
    SwitchCircle.Position = State and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
    SwitchCircle.Size = UDim2.new(0, 16, 0, 16)
    Instance.new("UICorner", SwitchCircle).CornerRadius = UDim.new(1, 0)
    
    ToggleFrame.MouseButton1Click:Connect(function()
        State = not State
        CreateTween(SwitchBg, {0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out}, {BackgroundColor3 = State and self.Library.Accent or Theme.Border})
        CreateTween(SwitchCircle, {0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out}, {Position = State and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)})
        if Config.Callback then task.spawn(Config.Callback, State) end
    end)
end

-- SLIDER
function NevoraHub:CreateSlider(Config)
    local Min, Max, Value = Config.Min or 0, Config.Max or 100, Config.Default or Config.Min or 0
    
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Parent = self.Container
    SliderFrame.BackgroundColor3 = Theme.Panel
    SliderFrame.Size = UDim2.new(1, 0, 0, 50)
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)
    
    local Label = Instance.new("TextLabel")
    Label.Parent = SliderFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 15, 0, 5)
    Label.Size = UDim2.new(1, -30, 0, 20)
    Label.Font = Enum.Font.GothamMedium
    Label.Text = Config.Name or "Slider"
    Label.TextColor3 = Theme.TextPrimary
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local ValueLabel = Label:Clone()
    ValueLabel.Parent = SliderFrame
    ValueLabel.Text = tostring(Value)
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    ValueLabel.TextColor3 = Theme.TextSecondary
    
    local SliderBg = Instance.new("Frame")
    SliderBg.Parent = SliderFrame
    SliderBg.BackgroundColor3 = Theme.Border
    SliderBg.Position = UDim2.new(0, 15, 0, 32)
    SliderBg.Size = UDim2.new(1, -30, 0, 6)
    Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(1, 0)
    
    local SliderFill = Instance.new("Frame")
    SliderFill.Parent = SliderBg
    SliderFill.BackgroundColor3 = self.Library.Accent
    SliderFill.Size = UDim2.new((Value - Min) / (Max - Min), 0, 1, 0)
    Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)
    
    local dragging = false
    local function UpdateSlider(input)
        local pos = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
        Value = math.floor(Min + ((Max - Min) * pos))
        ValueLabel.Text = tostring(Value)
        CreateTween(SliderFill, {0.1}, {Size = UDim2.new(pos, 0, 1, 0)})
        if Config.Callback then task.spawn(Config.Callback, Value) end
    end
    
    SliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            UpdateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input)
        end
    end)
end

-- [ NOTIFICATION SYSTEM ]
function NevoraHub:Notify(Config)
    if not self.Gui:FindFirstChild("NotificationContainer") then
        local Container = Instance.new("Frame")
        Container.Name = "NotificationContainer"
        Container.Parent = self.Gui
        Container.BackgroundTransparency = 1
        Container.Position = UDim2.new(1, -320, 1, -20)
        Container.Size = UDim2.new(0, 300, 1, 0)
        Container.AnchorPoint = Vector2.new(0, 1)
        
        local Layout = Instance.new("UIListLayout")
        Layout.Parent = Container
        Layout.SortOrder = Enum.SortOrder.LayoutOrder
        Layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        Layout.Padding = UDim.new(0, 10)
    end
    
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Parent = self.Gui.NotificationContainer
    NotifFrame.BackgroundColor3 = Theme.Panel
    NotifFrame.Size = UDim2.new(1, 0, 0, 65)
    NotifFrame.Position = UDim2.new(1, 50, 0, 0)
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", NotifFrame).Color = Theme.Border
    
    local Title = Instance.new("TextLabel")
    Title.Parent = NotifFrame
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 15, 0, 10)
    Title.Size = UDim2.new(1, -30, 0, 20)
    Title.Font = Enum.Font.GothamBold
    Title.Text = Config.Title or "Notification"
    Title.TextColor3 = Theme.TextPrimary
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left
    
    local Content = Instance.new("TextLabel")
    Content.Parent = NotifFrame
    Content.BackgroundTransparency = 1
    Content.Position = UDim2.new(0, 15, 0, 30)
    Content.Size = UDim2.new(1, -30, 0, 20)
    Content.Font = Enum.Font.Gotham
    Content.Text = Config.Content or "Message here"
    Content.TextColor3 = Theme.TextSecondary
    Content.TextSize = 13
    Content.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Progress Bar
    local Progress = Instance.new("Frame")
    Progress.Parent = NotifFrame
    Progress.BackgroundColor3 = Theme.Accent
    Progress.Position = UDim2.new(0, 0, 1, -2)
    Progress.Size = UDim2.new(1, 0, 0, 2)
    Progress.BorderSizePixel = 0
    
    -- Animasi Slide In
    CreateTween(NotifFrame, {0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out}, {Position = UDim2.new(0, 0, 0, 0)})
    
    -- Animasi Progress Bar
    local Dur = Config.Duration or 5
    CreateTween(Progress, {Dur, Enum.EasingStyle.Linear}, {Size = UDim2.new(0, 0, 0, 2)})
    
    task.delay(Dur, function()
        local out = CreateTween(NotifFrame, {0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In}, {Position = UDim2.new(1, 50, 0, 0), GroupTransparency = 1})
        out.Completed:Wait()
        NotifFrame:Destroy()
    end)
end

