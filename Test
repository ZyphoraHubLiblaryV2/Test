function Window:CreateToggleButton(config)
    config = config or {}
    local toggleBtn = {}

    toggleBtn.AssetId = config.AssetId or "rbxassetid://3926305904"
    toggleBtn.Size = config.Size or UDim2.new(0, 44, 0, 44)
    toggleBtn.Position = config.Position or UDim2.new(0, 20, 0, 20)
    toggleBtn.Visible = true
    toggleBtn.Draggable = config.Draggable ~= false

    -- Create the toggle button ScreenGui (separate from main window)
    toggleBtn.ScreenGui = Utility:Create("ScreenGui", {
        Name = "NevoraToggle_" .. Utility:GenerateId(),
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = Services.CoreGui,
    })

    -- Main button frame
    toggleBtn.Button = Utility:Create("TextButton", {
        Name = "ToggleButton",
        BackgroundColor3 = self.Theme.Accent,
        BorderSizePixel = 0,
        Position = toggleBtn.Position,
        Size = toggleBtn.Size,
        Text = "",
        Parent = toggleBtn.ScreenGui,
    })

    local corner = Utility:Create("UICorner", {
        CornerRadius = UDim.new(1, 0),
        Parent = toggleBtn.Button,
    })

    -- Shadow for button
    Utility:CreateShadow(toggleBtn.Button, 0.4, 4)

    -- Icon
    toggleBtn.Icon = Utility:Create("ImageLabel", {
        Name = "Icon",
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, -toggleBtn.Size.X.Offset/2 + 8, 0.5, -toggleBtn.Size.Y.Offset/2 + 8),
        Size = UDim2.new(0, toggleBtn.Size.X.Offset - 16, 0, toggleBtn.Size.Y.Offset - 16),
        Image = toggleBtn.AssetId,
        ImageColor3 = Color3.fromRGB(255, 255, 255),
        Parent = toggleBtn.Button,
    })

    -- Glow effect
    local glow = Utility:CreateGlow(toggleBtn.Button, self.Theme.Accent, 0.2)

    -- State tracking
    toggleBtn.WindowVisible = true

    -- Click animation
    toggleBtn.Button.MouseButton1Down:Connect(function()
        Utility:Tween(toggleBtn.Button, TweenInfo.new(0.1), {
            Size = UDim2.new(0, toggleBtn.Size.X.Offset * 0.9, 0, toggleBtn.Size.Y.Offset * 0.9),
            Position = UDim2.new(0, toggleBtn.Position.X.Offset + toggleBtn.Size.X.Offset * 0.05, 0, toggleBtn.Position.Y.Offset + toggleBtn.Size.Y.Offset * 0.05),
        })
    end)

    toggleBtn.Button.MouseButton1Up:Connect(function()
        Utility:Tween(toggleBtn.Button, TweenInfo.new(0.1), {
            Size = toggleBtn.Size,
            Position = toggleBtn.Position,
        })
    end)

    -- Toggle functionality
    toggleBtn.Button.MouseButton1Click:Connect(function()
        toggleBtn.WindowVisible = not toggleBtn.WindowVisible

        if toggleBtn.WindowVisible then
            -- Show window
            self.MainFrame.Visible = true
            Utility:Tween(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
                Size = self.Size,
                Position = UDim2.new(0.5, -self.Size.X.Offset/2, 0.5, -self.Size.Y.Offset/2),
            })
            -- Rotate icon back
            Utility:Tween(toggleBtn.Icon, TweenInfo.new(0.3), {Rotation = 0})
        else
            -- Hide window
            Utility:Tween(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0.5, 0, 0.5, 0),
            }, function()
                self.MainFrame.Visible = false
            end)
            -- Rotate icon
            Utility:Tween(toggleBtn.Icon, TweenInfo.new(0.3), {Rotation = 180})
        end
    end)

    -- Hover effects
    toggleBtn.Button.MouseEnter:Connect(function()
        Utility:Tween(toggleBtn.Button, TweenInfo.new(0.2), {
            BackgroundColor3 = self.Theme.Accent:Lerp(Color3.fromRGB(255, 255, 255), 0.15),
        })
        Utility:Tween(glow, TweenInfo.new(0.2), {
            ImageTransparency = 0.5,
        })
    end)

    toggleBtn.Button.MouseLeave:Connect(function()
        Utility:Tween(toggleBtn.Button, TweenInfo.new(0.2), {
            BackgroundColor3 = self.Theme.Accent,
        })
        Utility:Tween(glow, TweenInfo.new(0.2), {
            ImageTransparency = 0.7,
        })
    end)

    -- Make toggle button draggable if enabled
    if toggleBtn.Draggable then
        local dragging = false
        local dragStart = nil
        local startPos = nil

        toggleBtn.Button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = toggleBtn.Button.Position
            end
        end)

        Services.UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                            input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                local newPos = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
                toggleBtn.Button.Position = newPos
                toggleBtn.Position = newPos
            end
        end)

        Services.UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end

    -- Methods
    toggleBtn.SetVisible = function(visible)
        toggleBtn.Button.Visible = visible
    end

    toggleBtn.SetPosition = function(position)
        toggleBtn.Position = position
        toggleBtn.Button.Position = position
    end

    toggleBtn.SetAsset = function(assetId)
        toggleBtn.AssetId = assetId
        toggleBtn.Icon.Image = assetId
    end

    toggleBtn.Destroy = function()
        toggleBtn.ScreenGui:Destroy()
    end

    return toggleBtn
end

