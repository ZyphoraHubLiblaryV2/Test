function NevoraHub:Notify(title, text, duration)
    duration = duration or 3
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Parent = NotifyContainer
    NotifFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    NotifFrame.Size = UDim2.new(0, 220, 0, 55)
    NotifFrame.Position = UDim2.new(1, 60, 0, 0)
    NotifFrame.BackgroundTransparency = 1
    NotifFrame.ClipsDescendants = true

    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 8)

    local NTitle = Instance.new("TextLabel")
    NTitle.Parent = NotifFrame
    NTitle.BackgroundTransparency = 1
    NTitle.Position = UDim2.new(0, 12, 0, 6)
    NTitle.Size = UDim2.new(1, -20, 0, 18)
    NTitle.Font = Enum.Font.GothamBold
    NTitle.Text = title
    NTitle.TextColor3 = Color3.fromRGB(100, 180, 255)
    NTitle.TextSize = 14
    NTitle.TextXAlignment = Enum.TextXAlignment.Left
    NTitle.TextTransparency = 1

    local NText = Instance.new("TextLabel")
    NText.Parent = NotifFrame
    NText.BackgroundTransparency = 1
    NText.Position = UDim2.new(0, 12, 0, 26)
    NText.Size = UDim2.new(1, -20, 1, -34)
    NText.Font = Enum.Font.Gotham
    NText.Text = text
    NText.TextColor3 = Color3.fromRGB(200, 200, 210)
    NText.TextSize = 12
    NText.TextWrapped = true
    NText.TextXAlignment = Enum.TextXAlignment.Left
    NText.TextTransparency = 1

    TweenService:Create(NotifFrame, TweenInfo.new(0.35), {BackgroundTransparency = 0}):Play()
    TweenService:Create(NTitle, TweenInfo.new(0.35), {TextTransparency = 0}):Play()
    TweenService:Create(NText, TweenInfo.new(0.35), {TextTransparency = 0.2}):Play()
    TweenService:Create(NotifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, 0, 0, 0)}):Play()

    task.delay(duration, function()
        TweenService:Create(NotifFrame, TweenInfo.new(0.35), {BackgroundTransparency = 1}):Play()
        TweenService:Create(NTitle, TweenInfo.new(0.35), {TextTransparency = 1}):Play()
        TweenService:Create(NText, TweenInfo.new(0.35), {TextTransparency = 1}):Play()
        TweenService:Create(NotifFrame, TweenInfo.new(0.4), {Position = UDim2.new(1, 60, 0, 0)}):Play()
        task.wait(0.4)
        NotifFrame:Destroy()
    end)
end

