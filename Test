-- ZYPHORA ICON SUPPORT
-- ============================================
local IconSupport = loadstring(game:HttpGet("https://raw.githubusercontent.com/ZyphoraHubLiblaryV2/ZyphoraSupportIcon/refs/heads/main/SupportIconZyphora"))()

local function GetIcon(iconName)
    if not iconName or iconName == "" then return "rbxassetid://6031098371" end
    local icon = IconSupport[iconName]
    if icon then return icon end
    -- Fallback: cek apakah itu langsung rbxassetid
    if string.match(iconName, "^rbxassetid://") then return iconName end
    return "rbxassetid://6031098371"
end

