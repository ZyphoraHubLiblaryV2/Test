    local toggleBtn = CreateInstance("TextButton", {
        Parent = toggle,
        BackgroundTransparency = 1,
        Text = "",
        Size = UDim2.fromScale(1, 1)
    })
    
    local function updateToggle(newState)
        state = newState
        local targetPos = state and UDim2.fromOffset(18, 2) or UDim2.fromOffset(2, 2)
        local targetColor = state and tab.Library.Accent or DEFAULT_BACKGROUND
        
        ApplyTween(toggleKnob, TweenInfo.new(0.2), {
            Position = targetPos
        })
        
        ApplyTween(toggle, TweenInfo.new(0.2), {
            BackgroundColor3 = targetColor
        })
        
        if config.Callback then
            config.Callback(state)
        end
    end
    
    toggleBtn.MouseButton1Click:Connect(function()
        updateToggle(not state)
    end)
end

function NevoraHub.CreateTab.Slider = function(tab, config)
    local section = tab.Sections[#tab.Sections]
    if not section then return end
    
    local container = CreateInstance("Frame", {
        Parent = section.ItemsContainer,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 45)
    })
    
    local nameLabel = CreateInstance("TextLabel", {
        Parent = container,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = config.Name,
        TextColor3 = DEFAULT_TEXT,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(0.7, 0, 0, 18)
    })
    
    local currentValue = config.Default or config.Min
    local valueLabel = CreateInstance("TextLabel", {
        Parent = container,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = tostring(currentValue),
        TextColor3 = tab.Library.Accent,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        Position = UDim2.fromOffset(0, 0),
        Size = UDim2.new(1, 0, 0, 18)
    })
    
    -- Slider Track
    local sliderTrack = CreateInstance("Frame", {
        Name = "SliderTrack",
        Parent = container,
        BackgroundColor3 = DEFAULT_BACKGROUND,
        BorderSizePixel = 0,
        Position = UDim2.fromOffset(0, 22),
        Size = UDim2.new(1, 0, 0, 6)
    })
    
    CreateInstance("UICorner", {
        Parent = sliderTrack,
        CornerRadius = UDim.new(1, 0)
    })
    
    local sliderFill = CreateInstance("Frame", {
        Name = "SliderFill",
        Parent = sliderTrack,
        BackgroundColor3 = tab.Library.Accent,
        BorderSizePixel = 0,
        Size = UDim2.fromScale((currentValue - config.Min) / (config.Max - config.Min), 1)
    })
    
    CreateInstance("UICorner", {
        Parent = sliderFill,
        CornerRadius = UDim.new(1, 0)
    })
    
    local sliderKnob = CreateInstance("Frame", {
        Name = "SliderKnob",
        Parent = sliderFill,
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Position = UDim2.fromScale(1, 0.5),
        Size = UDim2.fromOffset(14, 14),
        AnchorPoint = Vector2.new(0.5, 0.5)
    })
    
    CreateInstance("UICorner", {
        Parent = sliderKnob,
        CornerRadius = UDim.new(1, 0)
    })
    
    -- Slider functionality
    local function updateSlider(input)
        local mousePos = UserInputService:GetMouseLocation()
        local trackPos = sliderTrack.AbsolutePosition
        local trackSize = sliderTrack.AbsoluteSize
        
        local relativeX = math.clamp((mousePos.X - trackPos.X) / trackSize.X, 0, 1)
        local newValue = math.floor(config.Min + (config.Max - config.Min) * relativeX)
        
        sliderFill.Size = UDim2.fromScale(relativeX, 1)
        valueLabel.Text = tostring(newValue)
        currentValue = newValue
        
        if config.Callback then
            config.Callback(newValue)
        end
    end
    
    local sliderBtn = CreateInstance("TextButton", {
        Parent = sliderTrack,
        BackgroundTransparency = 1,
        Text = "",
        Size = UDim2.fromScale(1, 1),
        ZIndex = 2
    })
    
    sliderBtn.MouseButton1Down:Connect(function()
        updateSlider()
        
        local connection
        connection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider()
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                connection:Disconnect()
            end
        end)
    end)
end

function NevoraHub.CreateTab.Dropdown = function(tab, config)
    local section = tab.Sections[#tab.Sections]
    if not section then return end
    
    local container = CreateInstance("Frame", {
        Parent = section.ItemsContainer,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 35),
        ClipsDescendants = true
    })
    
    local nameLabel = CreateInstance("TextLabel", {
        Parent = container,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = config.Name,
        TextColor3 = DEFAULT_TEXT,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(0.3, 0, 1, 0)
    })
    
    local selectedValue = config.Default or config.Options[1]
    
    local dropdownBtn = CreateInstance("TextButton", {
        Parent = container,
        BackgroundColor3 = DEFAULT_BACKGROUND,
        BorderSizePixel = 0,
        Font = Enum.Font.Gotham,
        Text = "  " .. selectedValue .. "  ▼",
        TextColor3 = DEFAULT_TEXT,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.fromScale(0.3, 0),
        Size = UDim2.new(0.7, 0, 1, 0),
        AutoButtonColor = false
    })
    
    CreateInstance("UICorner", {
        Parent = dropdownBtn,
        CornerRadius = UDim.new(0, 6)
    })
    
    -- Options list
    local optionsList = CreateInstance("ScrollingFrame", {
        Parent = container,
        BackgroundColor3 = DEFAULT_PANEL,
        BorderSizePixel = 0,
        Position = UDim2.fromOffset(0, 35),
        Size = UDim2.new(1, 0, 0, 0),
        CanvasSize = UDim2.fromScale(0, 0),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = tab.Library.Accent
    })
    
    CreateInstance("UICorner", {
        Parent = optionsList,
        CornerRadius = UDim.new(0, 6)
    })
    
    local optionLayout = CreateInstance("UIListLayout", {
        Parent = optionsList,
        SortOrder = Enum.SortOrder.LayoutOrder
    })
    
    local optionsOpen = false
    
    -- Create options
    for i, option in ipairs(config.Options) do
        local optionBtn = CreateInstance("TextButton", {
            Parent = optionsList,
            BackgroundTransparency = 1,
            Font = Enum.Font.Gotham,
            Text = "  " .. option,
            TextColor3 = DEFAULT_TEXT,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            Size = UDim2.new(1, 0, 0, 28),
            AutoButtonColor = false
        })
        
        optionBtn.MouseEnter:Connect(function()
            optionBtn.BackgroundColor3 = tab.Library.Accent
            optionBtn.BackgroundTransparency = 0.8
        end)
        
        optionBtn.MouseLeave:Connect(function()
            optionBtn.BackgroundTransparency = 1
        end)
        
        optionBtn.MouseButton1Click:Connect(function()
            selectedValue = option
            dropdownBtn.Text = "  " .. option .. "  ▼"
            
            -- Close dropdown
            optionsOpen = false
            ApplyTween(optionsList, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, 0)
            })
            ApplyTween(container, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, 35)
            })
            
            if config.Callback then
                config.Callback(option)
            end
        end)
    end
    
    dropdownBtn.MouseButton1Click:Connect(function()
        optionsOpen = not optionsOpen
        
        if optionsOpen then
            local totalHeight = #config.Options * 28
            ApplyTween(optionsList, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, totalHeight)
            })
            ApplyTween(container, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, 35 + totalHeight)
            })
        else
            ApplyTween(optionsList, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, 0)
            })
            ApplyTween(container, TweenInfo.new(0.2), {
                Size = UDim2.new(1, 0, 0, 35)
            })
        end
    end)
end

-- Notification System
function NevoraHub:Notify(notificationConfig)
    local notification = {
        Title = notificationConfig.Title or self.Title,
        Content = notificationConfig.Content or "",
        Duration = notificationConfig.Duration or 5,
        Type = notificationConfig.Type or "info"
    }
    
    -- Create notification frame
    local notifFrame = CreateInstance("Frame", {
        Name = "Notification",
        Parent = self.MainGui,
        BackgroundColor3 = DEFAULT_PANEL,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -10, 0, 10 + (#self.Notifications * 80)),
        Size = UDim2.fromOffset(0, 60),
        AnchorPoint = Vector2.new(1, 0),
        ClipsDescendants = true
    })
    
    CreateInstance("UICorner", {
        Parent = notifFrame,
        CornerRadius = UDim.new(0, 8)
    })
    
    -- Accent bar
    local accentColor = self.Accent
    if notification.Type == "error" then
        accentColor = Color3.fromRGB(255, 59, 48)
    elseif notification.Type == "warning" then
        accentColor = Color3.fromRGB(255, 149, 0)
    elseif notification.Type == "success" then
        accentColor = Color3.fromRGB(52, 199, 89)
    end
    
    CreateInstance("Frame", {
        Parent = notifFrame,
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Size = UDim2.fromOffset(3, 60)
    })
    
    -- Title
    CreateInstance("TextLabel", {
        Parent = notifFrame,
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = notification.Title,
        TextColor3 = DEFAULT_TEXT,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.fromOffset(15, 8),
        Size = UDim2.new(1, -30, 0, 18)
    })
    
    -- Content
    CreateInstance("TextLabel", {
        Parent = notifFrame,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = notification.Content,
        TextColor3 = DEFAULT_SUBTEXT,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.fromOffset(15, 28),
        Size = UDim2.new(1, -30, 0, 24)
    })
    
    -- Animate in
    ApplyTween(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(280, 60)
    })
    
    table.insert(self.Notifications, notification)
    
    -- Auto dismiss
    delay(notification.Duration, function()
        ApplyTween(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.fromOffset(0, 60)
        })
        
        delay(0.4, function()
            notifFrame:Destroy()
        end)
    end)
end

-- Utility Methods
function NevoraHub:ToggleMinimize()
    self.Minimized = not self.Minimized
    
    if self.Minimized then
        ApplyTween(self.ContentContainer, TweenInfo.new(0.3), {
            Size = UDim2.new(1, 0, 0, 0)
        })
    else
        ApplyTween(self.ContentContainer, TweenInfo.new(0.3), {
            Size = UDim2.new(1, 0, 1, -50)
        })
    end
end

function NevoraHub:ToggleVisible()
    self.Visible = not self.Visible
    self.MainGui.Enabled = self.Visible
    
    if self.Visible then
        self.Window.Visible = true
        ApplyTween(self.Window, TweenInfo.new(0.3), {
            Size = self.Size
        })
    else
        ApplyTween(self.Window, TweenInfo.new(0.3), {
            Size = UDim2.fromOffset(0, 0)
        })
    end
end

function NevoraHub:Destroy()
    self.MainGui:Destroy()
end

