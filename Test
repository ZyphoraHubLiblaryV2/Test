function Utility:Round(number, decimalPlaces)
    local mult = 10 ^ (decimalPlaces or 0)
    return math.floor(number * mult + 0.5) / mult
end

function Utility:FormatNumber(number)
    if number >= 1000000 then
        return string.format("%.1fM", number / 1000000)
    elseif number >= 1000 then
        return string.format("%.1fK", number / 1000)
    else
        return tostring(number)
    end
end

function Utility:Clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

function Utility:Lerp(a, b, t)
    return a + (b - a) * t
end

function Utility:Map(value, inMin, inMax, outMin, outMax)
    return (value - inMin) * (outMax - outMin) / (inMax - inMin) + outMin
end

function Utility:DeepCopy(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = Utility:DeepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

function Utility:GenerateId()
    return string.format("%08x", math.random(0, 0xFFFFFFFF))
end

