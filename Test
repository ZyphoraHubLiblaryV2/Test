    Utility.Corner(Track, 999)

    local Knob = Utility.Create("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = Color3.new(1, 1, 1),
        Parent = Track,
    })
    Utility.Corner(Knob, 999)

    local function setState(newState, fireCallback)
        state = newState
        Utility.Tween(Track, TweenInfo.new(0.2, EASE, DIR), {BackgroundColor3 = state and Theme.Accent or Theme.Stroke})
        Utility.Tween(Knob, TweenInfo.new(0.2, EASE, DIR), {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)})
        if fireCallback ~= false then
            local ok, err = pcall(callback, state)
            if not ok then warn("[Nevora Hub] Toggle callback error: " .. tostring(err)) end
        end
    end

    Track.MouseButton1Click:Connect(function()
        setState(not state)
    end)

    if config.Flag then
        self.Hub.Flags[config.Flag] = {Set = setState, Get = function() return state end}
    end

    setState(state, false)

    return {Set = setState, Get = function() return state end}
end

