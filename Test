    })
    
    self.Bar = Utility:Create("TextButton", {
        Parent = self.Instance,
        Size = UDim2.new(1, -20, 0, 6),
        Position = UDim2.new(0, 10, 0, 32),
        BackgroundColor3 = Nevora.Theme.ToggleOff,
        Text = "",
        AutoButtonColor = false
    })
    Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = self.Bar })
    
    self.Fill = Utility:Create("Frame", {
        Parent = self.Bar,
        Size = UDim2.new(math.clamp((self.Value - self.Min) / (self.Max - self.Min), 0, 1), 0, 1, 0),
        BackgroundColor3 = Nevora.Theme.Accent
    })
    Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = self.Fill })
    
    local isDragging = false
    local function UpdateSlider(input)
        local pos = math.clamp((input.Position.X - self.Bar.AbsolutePosition.X) / self.Bar.AbsoluteSize.X, 0, 1)
        self.Value = math.floor(self.Min + ((self.Max - self.Min) * pos))
        Utility:Tween(self.Fill, { Size = UDim2.new(pos, 0, 1, 0) }, 0.05, Enum.EasingStyle.Linear)
        self.ValueLabel.Text = tostring(self.Value)
        self.Callback(self.Value)
    end
    
    self.Bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            UpdateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input)
        end
    end)
    
    return self
end

