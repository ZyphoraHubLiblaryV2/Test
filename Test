-- ═══════════════════════════════════════════════════════════════

local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem

function ConfigSystem.new(libraryName)
    local self = setmetatable({}, ConfigSystem)
    self.LibraryName = libraryName or "NevoraHub"
    self.Configs = {}
    self.CurrentConfig = nil
    return self
end

function ConfigSystem:GetConfigPath()
    return self.LibraryName .. "_Configs"
end

function ConfigSystem:SaveConfig(name, data)
    name = name or "Default"
    local config = {
        Name = name,
        Data = data or {},
        Timestamp = os.time(),
    }
    self.Configs[name] = config
    pcall(function()
        local json = HttpService:JSONEncode(config)
        writefile(self:GetConfigPath() .. "/" .. name .. ".json", json)
    end)
    return config
end

function ConfigSystem:LoadConfig(name)
    name = name or "Default"
    local success, result = pcall(function()
        local json = readfile(self:GetConfigPath() .. "/" .. name .. ".json")
        return HttpService:JSONDecode(json)
    end)
    if success then
        self.CurrentConfig = result
        return result
    end
    return self.Configs[name]
end

function ConfigSystem:DeleteConfig(name)
    self.Configs[name] = nil
    pcall(function()
        delfile(self:GetConfigPath() .. "/" .. name .. ".json")
    end)
end

function ConfigSystem:ExportConfig(name)
    local config = self.Configs[name]
    if config then
        return HttpService:JSONEncode(config)
    end
    return nil
end

function ConfigSystem:ImportConfig(jsonString)
    local success, config = pcall(function()
        return HttpService:JSONDecode(jsonString)
    end)
    if success and config.Name then
        self.Configs[config.Name] = config
        return config
    end
    return nil
end

function ConfigSystem:ListConfigs()
    local list = {}
    for name, _ in pairs(self.Configs) do
        table.insert(list, name)
    end
    return list
end


