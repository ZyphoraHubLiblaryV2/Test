                end,
                Destroy = function(self)
                    div:Destroy()
                end
            }
        end

        -- Color Picker
        function Elements:AddColorPicker(settings)
            local color = settings.Color or Color3.fromRGB(255, 255, 255)
            
            local container = Instance.new("Frame")
            container.Parent = TabPage
            container.Size = UDim2.new(1, 0, 0, 38)
            container.BackgroundColor3 = currentTheme.ElementBackground
            container.ClipsDescendants = true
            Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)

            local label = Instance.new("TextLabel")
            label.Parent = container
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(0, 300, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.Text = settings.Name or "Color Picker"
            label.TextColor3 = currentTheme.TextColor
            label.Font = Enum.Font.Gotham
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left

            local colorDisplay = Instance.new("Frame")
            colorDisplay.Parent = container
            colorDisplay.Size = UDim2.new(0, 26, 0, 26)
            colorDisplay.Position = UDim2.new(1, -38, 0, 6)
            colorDisplay.BackgroundColor3 = color
            Instance.new("UICorner", colorDisplay).CornerRadius = UDim.new(0, 4)

            local expanded = false
            local obj = {
                Color = color,
                Set = function(self, newColor)
                    self.Color = newColor
                    colorDisplay.BackgroundColor3 = newColor
                    pcall(settings.Callback, newColor)
                    if settings.Flag then 
                        flags[settings.Flag] = {R = newColor.R * 255, G = newColor.G * 255, B = newColor.B * 255} 
                    end
                    if configEnabled then Window:SaveConfig() end
                end,
                Get = function(self)
                    return self.Color
                end,
                GetHex = function(self)
                    local c = self.Color
                    return string.format("#%02X%02X%02X", math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255))
                end
            }

            local pickerContainer = Instance.new("Frame")
            pickerContainer.Parent = container
            pickerContainer.BackgroundTransparency = 1
            pickerContainer.Size = UDim2.new(1, 0, 0, 0)
            pickerContainer.Position = UDim2.new(0, 0, 0, 38)

            local rBox = Instance.new("TextBox")
            rBox.Parent = pickerContainer
            rBox.Size = UDim2.new(0, 90, 0, 25)
            rBox.Position = UDim2.new(0, 12, 0, 6)
            rBox.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
            rBox.Text = tostring(math.floor(color.R * 255))
            rBox.TextColor3 = Color3.fromRGB(255, 200, 200)
            Instance.new("UICorner", rBox).CornerRadius = UDim.new(0, 3)

            local gBox = Instance.new("TextBox")
            gBox.Parent = pickerContainer
            gBox.Size = UDim2.new(0, 90, 0, 25)
            gBox.Position = UDim2.new(0, 110, 0, 6)
            gBox.BackgroundColor3 = Color3.fromRGB(20, 60, 20)
            gBox.Text = tostring(math.floor(color.G * 255))
            gBox.TextColor3 = Color3.fromRGB(200, 255, 200)
            Instance.new("UICorner", gBox).CornerRadius = UDim.new(0, 3)

            local bBox = Instance.new("TextBox")
            bBox.Parent = pickerContainer
            bBox.Size = UDim2.new(0, 90, 0, 25)
            bBox.Position = UDim2.new(0, 208, 0, 6)
            bBox.BackgroundColor3 = Color3.fromRGB(20, 20, 60)
            bBox.Text = tostring(math.floor(color.B * 255))
            bBox.TextColor3 = Color3.fromRGB(200, 200, 255)
            Instance.new("UICorner", bBox).CornerRadius = UDim.new(0, 3)

            local hexBox = Instance.new("TextBox")
            hexBox.Parent = pickerContainer
            hexBox.Size = UDim2.new(0, 100, 0, 25)
            hexBox.Position = UDim2.new(0, 12, 0, 38)
            hexBox.BackgroundColor3 = currentTheme.InputBackground
            hexBox.Text = obj:GetHex()
            hexBox.TextColor3 = currentTheme.TextColor
            hexBox.Font = Enum.Font.Gotham
            hexBox.TextSize = 12
            Instance.new("UICorner", hexBox).CornerRadius = UDim.new(0, 3)
            
            hexBox.FocusLost:Connect(function()
                local hex = hexBox.Text:gsub("#", "")
                if #hex == 6 then
                    local r = tonumber(hex:sub(1,2), 16) or 0
                    local g = tonumber(hex:sub(3,4), 16) or 0
                    local b = tonumber(hex:sub(5,6), 16) or 0
                    obj:Set(Color3.fromRGB(r, g, b))
                    rBox.Text = tostring(r)
                    gBox.Text = tostring(g)
                    bBox.Text = tostring(b)
                end
            end)

            local applyBtn = Instance.new("TextButton")
            applyBtn.Parent = pickerContainer
            applyBtn.Size = UDim2.new(0, 60, 0, 25)
            applyBtn.Position = UDim2.new(1, -72, 0, 6)
            applyBtn.BackgroundColor3 = currentTheme.ToggleEnabled
            applyBtn.Text = "Apply"
            applyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            applyBtn.Font = Enum.Font.GothamBold
            applyBtn.TextSize = 12
            Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 4)

            applyBtn.MouseButton1Click:Connect(function()
                local r = tonumber(rBox.Text) or 0
                local g = tonumber(gBox.Text) or 0
                local b = tonumber(bBox.Text) or 0
                obj:Set(Color3.fromRGB(r, g, b))
                hexBox.Text = obj:GetHex()
                expanded = false
                TweenService:Create(pickerContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 38)}):Play()
            end)

            container.MouseButton1Click:Connect(function()
                expanded = not expanded
                if expanded then
                    TweenService:Create(pickerContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 68)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 106)}):Play()
                else
                    TweenService:Create(pickerContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 38)}):Play()
                end
            end)

            if settings.Flag then 
                flags[settings.Flag] = {R = color.R * 255, G = color.G * 255, B = color.B * 255} 
            end
            return obj
        end

        -- New: Slider with text input
        function Elements:AddSliderWithInput(settings)
            local min = settings.Range and settings.Range[1] or 0
            local max = settings.Range and settings.Range[2] or 100
            local current = settings.CurrentValue or min
            local increment = settings.Increment or 1
            local suffix = settings.Suffix or ""
            
            local container = Instance.new("Frame")
            container.Parent = TabPage
            container.Size = UDim2.new(1, 0, 0, 60)
            container.BackgroundColor3 = currentTheme.ElementBackground
            Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)

            local label = Instance.new("TextLabel")
            label.Parent = container
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(0, 200, 0, 20)
            label.Position = UDim2.new(0, 12, 0, 5)
            label.Text = settings.Name or "Slider"
            label.TextColor3 = currentTheme.TextColor
            label.Font = Enum.Font.Gotham
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left

            local valueBox = Instance.new("TextBox")
            valueBox.Parent = container
            valueBox.Size = UDim2.new(0, 80, 0, 26)
            valueBox.Position = UDim2.new(1, -92, 0, 2)
            valueBox.BackgroundColor3 = currentTheme.InputBackground
            valueBox.Text = tostring(current)
            valueBox.TextColor3 = currentTheme.TextColor
            valueBox.Font = Enum.Font.GothamBold
            valueBox.TextSize = 13
            valueBox.TextXAlignment = Enum.TextXAlignment.Center
            Instance.new("UICorner", valueBox).CornerRadius = UDim.new(0, 4)

            local bar = Instance.new("Frame")
            bar.Parent = container
            bar.Size = UDim2.new(0, 380, 0, 6)
            bar.Position = UDim2.new(0, 12, 0, 42)
            bar.BackgroundColor3 = currentTheme.SliderBackground
            Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3)

            local fill = Instance.new("Frame")
            fill.Parent = bar
            fill.Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
            fill.BackgroundColor3 = currentTheme.SliderProgress
            Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

            local dragArea = Instance.new("TextButton")
            dragArea.Parent = container
            dragArea.Size = UDim2.new(0, 380, 0, 18)
            dragArea.Position = UDim2.new(0, 12, 0, 36)
            dragArea.BackgroundTransparency = 1
            dragArea.Text = ""

            local dragging = false
            local obj = {
                Value = current,
                Set = function(self, val)
                    val = math.clamp(val, min, max)
                    val = math.floor(val / increment + 0.5) * increment
                    current = val
                    self.Value = current
                    TweenService:Create(fill, TweenInfo.new(0.15), {
                        Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
                    }):Play()
                    valueBox.Text = tostring(current) .. suffix
                    pcall(settings.Callback, current)
                    if settings.Flag then flags[settings.Flag] = current end
                    if configEnabled then Window:SaveConfig() end
                end,
                Get = function(self)
                    return current
                end
            }

            valueBox.FocusLost:Connect(function()
                local val = tonumber(valueBox.Text:gsub(suffix, ""))
                if val then
                    obj:Set(val)
                else
                    valueBox.Text = tostring(current) .. suffix
                end
            end)

            dragArea.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then 
                    dragging = true 
                    local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    obj:Set(min + (pos * (max - min)))
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    obj:Set(min + (pos * (max - min)))
                end
            end)

            if settings.Flag then flags[settings.Flag] = current end
            return obj
        end

        return Elements
    end

    -- ============================================
    -- ADDITIONAL UTILITIES
    -- ============================================

    -- Get all flags
    function Window:GetFlags()
        return flags
    end

    -- Set flag value directly
    function Window:SetFlag(flag, value)
        if flags[flag] and flags[flag].Set then
            flags[flag]:Set(value)
        else
            flags[flag] = value
        end
    end

    -- Get flag value
    function Window:GetFlag(flag)
        if flags[flag] and flags[flag].Get then
            return flags[flag]:Get()
        end
        return flags[flag]
    end

    -- Reset all flags
    function Window:ResetFlags()
        for flag, obj in pairs(flags) do
            if type(obj) == "table" and obj.Set then
                if obj.Value ~= nil then
                    obj:Set(obj.Value)
                end
            end
        end
    end

    -- Destroy window
    function Window:Destroy()
        if autoSaveInterval then
            task.cancel(autoSaveInterval)
        end
        for _, conn in pairs(keybindConnections) do
            conn:Disconnect()
        end
        MainFrame:Destroy()
        NevoraHub:Notify({Title = "Closed", Content = "Nevora Hub closed", Duration = 2})
    end

    -- Auto load config if enabled
    if autoLoad then
        task.delay(0.5, function()
            Window:LoadConfig()
        end)
    end

    -- Main content scroll fix
    local function updateMainContentSize()
        MainContent.CanvasSize = UDim2.new(0, 0, 0, MainLayout.AbsoluteContentSize.Y + 24)
    end
    
    MainLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateMainContentSize)
    
    return Window
end

