local AnimationEngine = {}
AnimationEngine.__index = AnimationEngine

function AnimationEngine.new()
    local self = setmetatable({}, AnimationEngine)
    self.ActiveAnimations = {}
    self.Maid = Maid.new()
    return self
end

function AnimationEngine:Spring(instance, target, stiffness, damping)
    stiffness = stiffness or 500
    damping = damping or 50

    local connection
    local velocity = Vector2.new(0, 0)
    local current = Vector2.new(instance.Position.X.Offset, instance.Position.Y.Offset)
    local goal = Vector2.new(target.X.Offset, target.Y.Offset)

    connection = RunService.RenderStepped:Connect(function(dt)
        local force = (goal - current) * stiffness
        velocity = velocity + force * dt
        velocity = velocity * (1 - damping * dt)
        current = current + velocity * dt

        instance.Position = UDim2.new(target.X.Scale, current.X, target.Y.Scale, current.Y)

        if (goal - current).Magnitude < 0.5 and velocity.Magnitude < 0.5 then
            instance.Position = target
            connection:Disconnect()
        end
    end)

    self.Maid:GiveTask(connection)
    return connection
end

function AnimationEngine:Pulse(instance, minScale, maxScale, duration)
    minScale = minScale or 1
    maxScale = maxScale or 1.05
    duration = duration or 1.5

    local tween1 = TweenService:Create(instance, TweenInfo.new(duration / 2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        Size = UDim2.new(instance.Size.X.Scale * maxScale, instance.Size.X.Offset,
                         instance.Size.Y.Scale * maxScale, instance.Size.Y.Offset)
    })

    local tween2 = TweenService:Create(instance, TweenInfo.new(duration / 2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        Size = UDim2.new(instance.Size.X.Scale * minScale, instance.Size.X.Offset,
                         instance.Size.Y.Scale * minScale, instance.Size.Y.Offset)
    })

    tween1.Completed:Connect(function()
        tween2:Play()
    end)
    tween2.Completed:Connect(function()
        tween1:Play()
    end)

    tween1:Play()
    return { tween1, tween2 }
end

function AnimationEngine:Breathing(instance, minTransparency, maxTransparency, duration)
    minTransparency = minTransparency or 0.7
    maxTransparency = maxTransparency or 0.9
    duration = duration or 2

    local tween1 = TweenService:Create(instance, TweenInfo.new(duration / 2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        BackgroundTransparency = maxTransparency
    })
    local tween2 = TweenService:Create(instance, TweenInfo.new(duration / 2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        BackgroundTransparency = minTransparency
    })

    tween1.Completed:Connect(function()
        tween2:Play()
    end)
    tween2.Completed:Connect(function()
        tween1:Play()
    end)

    tween1:Play()
    return { tween1, tween2 }
end

function AnimationEngine:Float(instance, amplitude, duration)
    amplitude = amplitude or 5
    duration = duration or 2
    local originalY = instance.Position.Y.Offset
    local startTime = tick()

    local connection = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local offset = math.sin(elapsed / duration * math.pi * 2) * amplitude
        instance.Position = UDim2.new(
            instance.Position.X.Scale, instance.Position.X.Offset,
            instance.Position.Y.Scale, originalY + offset
        )
    end)

    self.Maid:GiveTask(connection)
    return connection
end

function AnimationEngine:Destroy()
    self.Maid:Destroy()
end

