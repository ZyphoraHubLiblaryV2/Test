            label.TextXAlignment = Enum.TextXAlignment.Left

            local valueLabel = Instance.new("TextLabel")
            valueLabel.Parent = container
            valueLabel.BackgroundTransparency = 1
            valueLabel.Size = UDim2.new(0, 80, 0, 20)
            valueLabel.Position = UDim2.new(1, -92, 0, 5)
            valueLabel.Text = tostring(current) .. (suffix or "")
            valueLabel.TextColor3 = Color3.fromRGB(100, 180, 255)
            valueLabel.Font = Enum.Font.GothamBold
            valueLabel.TextSize = 13
            valueLabel.TextXAlignment = Enum.TextXAlignment.Right

            local bar = Instance.new("Frame")
            bar.Parent = container
            bar.Size = UDim2.new(0, 380, 0, 6)
            bar.Position = UDim2.new(0, 12, 0, 32)
            bar.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3)

            local fill = Instance.new("Frame")
            fill.Parent = bar
            fill.Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
            fill.BackgroundColor3 = Color3.fromRGB(50, 150, 255)
            Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

            local dragArea = Instance.new("TextButton")
            dragArea.Parent = container
            dragArea.Size = UDim2.new(0, 380, 0, 18)
            dragArea.Position = UDim2.new(0, 12, 0, 26)
            dragArea.BackgroundTransparency = 1
            dragArea.Text = ""

            local dragging = false
            local obj = {
                Value = current,
                Set = function(self, val)
                    val = math.clamp(val, min, max)
                    current = val
                    self.Value = current
                    TweenService:Create(fill, TweenInfo.new(0.15), {
                        Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
                    }):Play()
                    valueLabel.Text = tostring(current) .. (suffix or "")
                    pcall(callback, current)
                    if flag then flags[flag] = current end
                    if configEnabled then Window:SaveConfig() end
                end
            }

            dragArea.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then 
                    dragging = true 
                    local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    obj:Set(min + (pos * (max - min)))
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then 
                    dragging = false 
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    obj:Set(min + (pos * (max - min)))
                end
            end)

            if flag then flags[flag] = current end
            elementObjects[flag] = obj
            return obj
        end

