local Utility = {}

function Utility.Create(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            instance[prop] = value
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility.Tween(instance, tweenInfo, properties, callback)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    if callback then
        tween.Completed:Connect(callback)
    end
    tween:Play()
    return tween
end

function Utility.FadeIn(instance, duration)
    instance.BackgroundTransparency = 1
    Utility.Tween(instance, TweenInfo.new(duration or 0.3), {
        BackgroundTransparency = instance:GetAttribute("OriginalTransparency") or 0
    })
end

function Utility.FadeOut(instance, duration, callback)
    Utility.Tween(instance, TweenInfo.new(duration or 0.3), {
        BackgroundTransparency = 1
    }, function()
        if callback then callback() end
    end)
end

function Utility.SlideIn(instance, direction, duration)
    local originalPos = instance.Position
    local offset = direction == "Left" and UDim2.new(-1, 0, 0, 0)
        or direction == "Right" and UDim2.new(1, 0, 0, 0)
        or direction == "Top" and UDim2.new(0, 0, -1, 0)
        or UDim2.new(0, 0, 1, 0)

    instance.Position = originalPos + offset
    Utility.Tween(instance, TweenInfo.new(duration or 0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = originalPos
    })
end

function Utility.CreateRipple(parent, position)
    local ripple = Utility.Create("Frame", {
        Name = "Ripple",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = position or UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = Constants.Accent,
        BackgroundTransparency = 0.8,
        BorderSizePixel = 0,
        ZIndex = parent.ZIndex + 1,
        Parent = parent,
    })

    local corner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(1, 0),
        Parent = ripple,
    })

    local maxSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2

    Utility.Tween(ripple, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1,
    }, function()
        ripple:Destroy()
    end)
end

function Utility.CreateGlow(parent, color, size)
    local glow = Utility.Create("ImageLabel", {
        Name = "Glow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, size or 20, 1, size or 20),
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857084",
        ImageColor3 = color or Constants.Accent,
        ImageTransparency = 0.9,
        ZIndex = parent.ZIndex - 1,
        Parent = parent,
    })
    return glow
end

function Utility.CreateGlass(parent, transparency)
    local glass = Utility.Create("Frame", {
        Name = "Glass",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Constants.Card,
        BackgroundTransparency = transparency or 0.3,
        BorderSizePixel = 0,
        Parent = parent,
    })

    local corner = Utility.Create("UICorner", {
        CornerRadius = Constants.CornerRadius,
        Parent = glass,
    })

    local stroke = Utility.Create("UIStroke", {
        Color = Constants.Border,
        Thickness = 1,
        Transparency = 0.5,
        Parent = glass,
    })

    return glass
end

function Utility.Debounce(func, delay)
    delay = delay or Constants.DebounceTime
    local isRunning = false
    return function(...)
        if not isRunning then
            isRunning = true
            func(...)
            task.delay(delay, function()
                isRunning = false
            end)
        end
    end
end

function Utility.DarkenColor(color, amount)
    amount = amount or 0.2
    return Color3.new(
        math.clamp(color.R - amount, 0, 1),
        math.clamp(color.G - amount, 0, 1),
        math.clamp(color.B - amount, 0, 1)
    )
end

function Utility.LightenColor(color, amount)
    amount = amount or 0.2
    return Color3.new(
        math.clamp(color.R + amount, 0, 1),
        math.clamp(color.G + amount, 0, 1),
        math.clamp(color.B + amount, 0, 1)
    )
end

function Utility.FormatNumber(num)
    if num >= 1000000 then
        return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    end
    return tostring(num)
end

