            Parent = rowFrame,
            Size = UDim2.new(colWidth, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = cellText,
            TextColor3 = Nevora.Theme.Text,
            Font = Nevora.Theme.Font,
            TextSize = 12
        })
    end
    
    table.insert(self.Rows, rowFrame)
