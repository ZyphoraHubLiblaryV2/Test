        })
        Modules.Utilities:CreateInstance("UICorner", node, "Corner", { CornerRadius = UDim.new(1, 0) })
        
        switch.MouseButton1Click:Connect(function()
            toggled = not toggled
            local targetPos = toggled and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
            local targetColor = toggled and self.MainLib.Theme.Accent or self.MainLib.Theme.Secondary
            
            TweenService:Create(node, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
            TweenService:Create(switch, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
            task.spawn(callback, toggled)
        end)
        
        return card
    end
    
    function Elements:AddSlider(text, min, max, default, callback)
        local value = math.clamp(default or min, min, max)
        
        local card = Modules.Utilities:CreateInstance("Frame", self.PageFrame, "SliderCard", {
            Size = UDim2.new(1, -5, 0, 65),
            BackgroundColor3 = self.MainLib.Theme.Card,
            BorderSizePixel = 0
        })
        Modules.Utilities:CreateInstance("UICorner", card, "Corner", { CornerRadius = UDim.new(0, 8) })
        Modules.Utilities:CreateInstance("UIStroke", card, "Stroke", { Color = self.MainLib.Theme.Border })
        
        Modules.Utilities:CreateInstance("TextLabel", card, "Label", {
            Size = UDim2.new(0, 200, 0, 30),
            Position = UDim2.new(0, 15, 0, 5),
            Text = text,
            TextColor3 = self.MainLib.Theme.Text,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1
        })
        
        local valLabel = Modules.Utilities:CreateInstance("TextLabel", card, "Value", {
            Size = UDim2.new(0, 100, 0, 30) persistence,
            Position = UDim2.new(1, -115, 0, 5),
            Text = tostring(value),
            TextColor3 = self.MainLib.Theme.Accent,
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Right,
            BackgroundTransparency = 1
        })
        
        local track = Modules.Utilities:CreateInstance("TextButton", card, "Track", {
            Size = UDim2.new(1, -30, 0, 6),
            Position = UDim2.new(0, 15, 1, -18),
            BackgroundColor3 = self.MainLib.Theme.Secondary,
            Text = ""
        })
        Modules.Utilities:CreateInstance("UICorner", track, "Corner", { CornerRadius = UDim.new(1, 0) })
        
        local fill = Modules.Utilities:CreateInstance("Frame", track, "Fill", {
            Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
            BackgroundColor3 = self.MainLib.Theme.Accent,
            BorderSizePixel = 0
        })
        Modules.Utilities:CreateInstance("UICorner", fill, "Corner", { CornerRadius = UDim.new(1, 0) })
        
        local isSliding = false
        local function snap(input)
            local percentage = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            value = math.round(min + (max - min) * percentage)
            valLabel.Text = tostring(value)
            TweenService:Create(fill, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {Size = UDim2.new(percentage, 0, 1, 0)}):Play()
            task.spawn(callback, value)
        end
        
        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isSliding = true
                snap(input)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                snap(input)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isSliding = false
            end
        end)
    end
    
    function Elements:AddButton(text, callback)
        local btn = Modules.Utilities:CreateInstance("TextButton", self.PageFrame, "Button", {
            Size = UDim2.new(1, -5, 0, 45),
            BackgroundColor3 = self.MainLib.Theme.Card,
            Text = "",
            BorderSizePixel = 0
        })
        Modules.Utilities:CreateInstance("UICorner", btn, "Corner", { CornerRadius = UDim.new(0, 8) })
        local stroke = Modules.Utilities:CreateInstance("UIStroke", btn, "Stroke", { Color = self.MainLib.Theme.Border })
        local scale = Modules.Utilities:CreateInstance("UIScale", btn, "Scale")
        
        Modules.Utilities:CreateInstance("TextLabel", btn, "Label", {
            Size = UDim2.new(1, 0, 1, 0),
            Text = text,
            TextColor3 = self.MainLib.Theme.Text,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            BackgroundTransparency = 1
        })
        
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.MainLib.Theme.Secondary}):Play()
            TweenService:Create(stroke, TweenInfo.new(0.2), {Color = self.MainLib.Theme.Accent}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.MainLib.Theme.Card}):Play()
            TweenService:Create(stroke, TweenInfo.new(0.2), {Color = self.MainLib.Theme.Border}):Play()
        end)
        btn.MouseButton1Click:Connect(function()
            scale.Scale = 0.95
            TweenService:Create(scale, TweenInfo.new(0.15, Enum.EasingStyle.Back), {Scale = 1}):Play()
            task.spawn(callback)
        end)
        
        return btn
    end
    
    return Elements
end)()

