function Section:CreateSlider(options)
    options = options or {}
    local slider = {}
    slider.Min = options.Min or 0
    slider.Max = options.Max or 100
    slider.Value = options.Default or slider.Min
    slider.Decimals = options.Decimals or 0
    slider.Callback = options.Callback
    slider.Suffix = options.Suffix or ""

    local sliderFrame = Utility.Create("Frame", {
        Name = options.Name or "Slider",
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = self.ComponentContainer,
    })

    local label = Utility.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(0.5, 0, 0, 18),
        BackgroundTransparency = 1,
        Text = options.Text or "Slider",
        TextColor3 = Constants.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = sliderFrame,
    })

    local valueLabel = Utility.Create("TextLabel", {
        Name = "Value",
        Size = UDim2.new(0.5, 0, 0, 18),
        Position = UDim2.new(0.5, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(slider.Value) .. slider.Suffix,
        TextColor3 = Constants.Accent,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = sliderFrame,
    })

    local track = Utility.Create("Frame", {
        Name = "Track",
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 32),
        BackgroundColor3 = Constants.Border,
        BorderSizePixel = 0,
        Parent = sliderFrame,
    })

    local trackCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(1, 0),
        Parent = track,
    })

    local fill = Utility.Create("Frame", {
        Name = "Fill",
        Size = UDim2.new((slider.Value - slider.Min) / (slider.Max - slider.Min), 0, 1, 0),
        BackgroundColor3 = Constants.Accent,
        BorderSizePixel = 0,
        Parent = track,
    })

    local fillCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(1, 0),
        Parent = fill,
    })

    local knob = Utility.Create("Frame", {
        Name = "Knob",
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new((slider.Value - slider.Min) / (slider.Max - slider.Min), -8, 0.5, -8),
        BackgroundColor3 = Constants.TextPrimary,
        BorderSizePixel = 0,
        Parent = track,
    })

    local knobCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(1, 0),
        Parent = knob,
    })

    local knobGlow = Utility.Create("ImageLabel", {
        Name = "Glow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 10, 1, 10),
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857084",
        ImageColor3 = Constants.Accent,
        ImageTransparency = 0.9,
        Parent = knob,
    })

    local dragging = false

    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = slider.Min + (pos * (slider.Max - slider.Min))

        if slider.Decimals > 0 then
            value = math.floor(value * (10 ^ slider.Decimals)) / (10 ^ slider.Decimals)
        else
            value = math.floor(value)
        end

        slider.Value = value
        valueLabel.Text = tostring(value) .. slider.Suffix

        Utility.Tween(fill, Constants.TweenInfo.Fast, {
            Size = UDim2.new(pos, 0, 1, 0),
        })

        Utility.Tween(knob, Constants.TweenInfo.Fast, {
            Position = UDim2.new(pos, -8, 0.5, -8),
        })

        if slider.Callback then
            slider.Callback(value)
        end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                        input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    slider.Instance = sliderFrame
    slider.SetValue = function(_, value)
        value = math.clamp(value, slider.Min, slider.Max)
        if slider.Decimals > 0 then
            value = math.floor(value * (10 ^ slider.Decimals)) / (10 ^ slider.Decimals)
        else
            value = math.floor(value)
        end

        slider.Value = value
        local pos = (value - slider.Min) / (slider.Max - slider.Min)
        valueLabel.Text = tostring(value) .. slider.Suffix

        Utility.Tween(fill, Constants.TweenInfo.Fast, {
            Size = UDim2.new(pos, 0, 1, 0),
        })

        Utility.Tween(knob, Constants.TweenInfo.Fast, {
            Position = UDim2.new(pos, -8, 0.5, -8),
        })

        if slider.Callback then
            slider.Callback(value)
        end
    end

    table.insert(self.Components, slider)
    return slider
end

