    }
    local json = Services.HttpService:JSONEncode(config)
    return json
end

function Nevora:LoadConfig(json)
    local success, config = pcall(function()
        return Services.HttpService:JSONDecode(json)
    end)
    if success then
        return config.Data
    end
    return nil
end

function Nevora:ExportConfig(data)
    return Services.HttpService:JSONEncode(data)
end

function Nevora:ImportConfig(json)
    local success, data = pcall(function()
        return Services.HttpService:JSONDecode(json)
    end)
    if success then
        return data
    end
    return nil
end

