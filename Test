function NevoraHub:ShowLoading()
    -- Animate loading bar
    local tween = ApplyTween(self.LoadingFill, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.fromScale(1, 1)
    })
    
    tween.Completed:Wait()
    wait(0.3)
    
    -- Fade out loading screen
    ApplyTween(self.LoadingScreen, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        BackgroundTransparency = 1
    })
    
    for _, child in pairs(self.LoadingScreen:GetChildren()) do
        if child:IsA("GuiObject") then
            ApplyTween(child, TweenInfo.new(0.5), {
                BackgroundTransparency = 1,
                TextTransparency = 1
            })
        end
    end
    
    wait(0.5)
    self.LoadingScreen:Destroy()
    self.Loaded = true
end

-- Tab Management
function NevoraHub:CreateTab(tabConfig)
    local tab = {
        Name = tabConfig.Name,
        Icon = tabConfig.Icon or "circle",
        Library = self,
        Sections = {},
        Button = nil
    }
    
    -- Create Tab Button
    local tabBtn = CreateInstance("TextButton", {
        Name = tabConfig.Name,
        Parent = self.TabContainer,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = "  " .. (tabConfig.Icon and "⬤ " or "") .. tabConfig.Name,
        TextColor3 = DEFAULT_SUBTEXT,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, -20, 0, 35),
        Position = UDim2.fromOffset(10, 0),
        AutoButtonColor = false
    })
    
    -- Tab button hover effects
    tabBtn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tab then
            ApplyTween(tabBtn, TweenInfo.new(0.2), {
                TextColor3 = DEFAULT_TEXT
            })
        end
    end)
    
    tabBtn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tab then
            ApplyTween(tabBtn, TweenInfo.new(0.2), {
                TextColor3 = DEFAULT_SUBTEXT
            })
        end
    end)
    
    tabBtn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)
    
    -- Create Tab Content Page
    tab.Content = CreateInstance("Frame", {
        Name = tabConfig.Name .. "Content",
        Parent = self.ContentScroll,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Visible = false
    })
    
    local tabLayout = CreateInstance("UIListLayout", {
        Parent = tab.Content,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 10)
    })
    
    tab.Button = tabBtn
    table.insert(self.Tabs, tab)
    
    -- Auto-select first tab
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    return tab
end

function NevoraHub:SelectTab(tab)
    if self.ActiveTab == tab then return end
    
    -- Deselect previous tab
    if self.ActiveTab then
        self.ActiveTab.Content.Visible = false
        
        if self.ActiveTab.Button then
            ApplyTween(self.ActiveTab.Button, TweenInfo.new(0.2), {
                TextColor3 = DEFAULT_SUBTEXT
            })
        end
    end
    
    -- Select new tab
    self.ActiveTab = tab
    tab.Content.Visible = true
    
    if tab.Button then
        ApplyTween(tab.Button, TweenInfo.new(0.2), {
            TextColor3 = self.Accent
        })
        
        -- Create accent indicator
        if not tab.Indicator then
            tab.Indicator = CreateInstance("Frame", {
                Name = "Indicator",
                Parent = tab.Button,
                BackgroundColor3 = self.Accent,
                BorderSizePixel = 0,
                Position = UDim2.fromOffset(0, 0),
                Size = UDim2.fromOffset(2, 30)
            })
            
            CreateInstance("UICorner", {
                Parent = tab.Indicator,
                CornerRadius = UDim.new(1, 0)
            })
        end
        
        ApplyTween(tab.Indicator, TweenInfo.new(0.2), {
            BackgroundTransparency = 0
        })
    end
    
    -- Animate content
    ApplyTween(tab.Content, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.fromOffset(0, 0)
    })
    
    -- Update canvas size
    self.ContentScroll.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 20)
end

