-- ZYPHORA ICON SUPPORT
-- ============================================
local IconSupport = {}
local function LoadIcons()
    local success, result = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/ZyphoraHubLiblaryV2/ZyphoraSupportIcon/refs/heads/main/SupportIconZyphora"))()
    end)
    if success and result then
        IconSupport = result
    else
        IconSupport = {}
    end
end
LoadIcons()

local function GetIcon(iconName)
    if not iconName or iconName == "" then return "" end
    if IconSupport[iconName] then return IconSupport[iconName] end
    if string.match(iconName, "^rbxassetid://") then return iconName end
    return ""
end

