        self.InputX.Text = tostring(x)
        self.InputY.Text = tostring(y)
        self.InputZ.Text = tostring(z)
        self.Value = Vector3.new(x, y, z)
        self.Callback(self.Value)
    end
    
    self.InputX.FocusLost:Connect(ProcessInput)
    self.InputY.FocusLost:Connect(ProcessInput)
    self.InputZ.FocusLost:Connect(ProcessInput)
    
    return self
end

