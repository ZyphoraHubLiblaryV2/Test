-- MAID / CLEANER SYSTEM
-- ═══════════════════════════════════════════════════════════

local Maid = {}
Maid.__index = Maid

function Maid.new()
    local self = setmetatable({}, Maid)
    self._tasks = {}
    return self
end

function Maid:Give(task)
    table.insert(self._tasks, task)
    return task
end

function Maid:GiveTask(task)
    return self:Give(task)
end

function Maid:Clean()
    for _, task in ipairs(self._tasks) do
        if typeof(task) == "RBXScriptConnection" then
            task:Disconnect()
        elseif typeof(task) == "Instance" then
            task:Destroy()
        elseif type(task) == "function" then
            task()
        elseif type(task) == "table" and task.Destroy then
            task:Destroy()
        end
    end
    self._tasks = {}
end

function Maid:Destroy()
    self:Clean()
end

-- ═══════════════════════════════════════════════════════════
-- DRAGGABLE SYSTEM (Mobile Optimized)
-- ═══════════════════════════════════════════════════════════

local Draggable = {}

function Draggable.new(frame, handle)
    local self = {}
    local dragging = false
    local dragStart = nil
    local startPos = nil
    local maid = Maid.new()

    handle = handle or frame

    maid:Give(handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end))

    maid:Give(Services.UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                        input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end))

    maid:Give(Services.UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))

    self.Destroy = function()
        maid:Destroy()
    end

    return self
end

-- ═══════════════════════════════════════════════════════════
-- RESIZABLE SYSTEM (Mobile Optimized with Bigger Handle)
-- ═══════════════════════════════════════════════════════════

local Resizable = {}

function Resizable.new(frame, minSize, maxSize)
    local self = {}
    local resizing = false
    local resizeStart = nil
    local startSize = nil
    local maid = Maid.new()

    minSize = minSize or Vector2.new(200, 150)
    maxSize = maxSize or Vector2.new(1920, 1080)

    -- Bigger handle for mobile (25x25 instead of 15x15)
    local handle = Utility:Create("Frame", {
        Name = "ResizeHandle",
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -25, 1, -25),
        Size = UDim2.new(0, 25, 0, 25),
        ZIndex = frame.ZIndex + 10,
        Parent = frame,
    })

    local icon = Utility:Create("ImageLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        Image = "rbxassetid://3926305904",
        ImageRectOffset = Vector2.new(524, 764),
        ImageRectSize = Vector2.new(36, 36),
        ImageColor3 = Color3.fromRGB(100, 110, 130),
        ImageTransparency = 0.5,
        Parent = handle,
    })

    maid:Give(handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            resizing = true
            resizeStart = input.Position
            startSize = frame.AbsoluteSize
        end
    end))

    maid:Give(Services.UserInputService.InputChanged:Connect(function(input)
        if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or
                        input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - resizeStart
            local newSize = Vector2.new(
                math.clamp(startSize.X + delta.X, minSize.X, maxSize.X),
                math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
            )
            frame.Size = UDim2.new(0, newSize.X, 0, newSize.Y)
        end
    end))

    maid:Give(Services.UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            resizing = false
        end
    end))

    self.Destroy = function()
        maid:Destroy()
    end

    return self
end

