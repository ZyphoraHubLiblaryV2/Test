            Font = Enum.Font.Code,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = outputScroll,
        })

        table.insert(terminal.History, line)

        task.delay(0.05, function()
            outputScroll.CanvasPosition = Vector2.new(0, outputScroll.AbsoluteCanvasSize.Y)
        end)
    end

    input.FocusLost:Connect(function(enterPressed)
        if enterPressed and input.Text ~= "" then
            terminal:Print("> " .. input.Text, Constants.Accent)

            local args = {}
            for arg in input.Text:gmatch("%S+") do
                table.insert(args, arg)
            end

            local cmd = args[1]
            table.remove(args, 1)

            if terminal.Commands[cmd] then
                local success, result = pcall(function()
                    return terminal.Commands[cmd](args)
                end)
                if success then
                    if result then terminal:Print(result, Constants.Success) end
                else
                    terminal:Print("Error: " .. tostring(result), Constants.Error)
                end
            else
                terminal:Print("Unknown command: " .. cmd, Constants.Error)
            end

            input.Text = ""
        end
    end)

    terminal.Instance = termFrame

    table.insert(self.Components, terminal)
    return terminal
end

