    local bcFrame = Utility.Create("Frame", {
        Name = options.Name or "Breadcrumb",
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        Parent = self.ComponentContainer,
    })

    local layout = Utility.Create("UIListLayout", {
        Padding = UDim.new(0, 4),
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = bcFrame,
    })

    local function build()
        for _, child in ipairs(bcFrame:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("ImageLabel") then
                child:Destroy()
            end
        end

        for i, item in ipairs(bc.Items) do
            local label = Utility.Create("TextLabel", {
                Name = "Item" .. i,
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = item,
