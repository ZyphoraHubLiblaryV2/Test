-- Acrylic Blur System
local AcrylicSystem = {}

function AcrylicSystem:Init()
    self.DepthOfField = Create("DepthOfFieldEffect", {
        FarIntensity = 0,
        InFocusRadius = 0.1,
        NearIntensity = 1,
        Parent = Lighting
    })

    self.OriginalEffects = {}

    for _, effect in pairs(Lighting:GetDescendants()) do
        if effect:IsA("DepthOfFieldEffect") then
            self.OriginalEffects[effect] = effect.Enabled
            effect.Enabled = false
        end
    end
end

function AcrylicSystem:Enable()
    self.DepthOfField.Parent = Lighting
end

function AcrylicSystem:Disable()
    self.DepthOfField.Parent = nil
    for effect, enabled in pairs(self.OriginalEffects) do
        if effect and effect.Parent then
            effect.Enabled = enabled
        end
    end
end

function AcrylicSystem:CreateBlur(parent)
    local blurPart = Create("Part", {
        Name = "AcrylicBlur",
        Size = Vector3.new(1, 1, 0.01),
        Anchored = true,
        CanCollide = false,
        Locked = true,
        CastShadow = false,
        Transparency = 0.98,
        Material = Enum.Material.Glass,
        Parent = Workspace.CurrentCamera
    })

    local mesh = Create("SpecialMesh", {
        MeshType = Enum.MeshType.Brick,
        Offset = Vector3.new(0, 0, -0.001),
        Parent = blurPart
    })

    local frame = Create("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local function Update()
        local camera = Workspace.CurrentCamera
        if not camera then return end

        local pos = frame.AbsolutePosition
        local size = frame.AbsoluteSize

        local topLeft = camera:ViewportPointToRay(pos.X, pos.Y)
        local bottomRight = camera:ViewportPointToRay(pos.X + size.X, pos.Y + size.Y)

        local worldPos = (topLeft.Origin + topLeft.Direction * 10)
        local worldSize = (bottomRight.Origin + bottomRight.Direction * 10) - worldPos

        blurPart.CFrame = CFrame.new(worldPos + worldSize / 2)
        blurPart.Size = Vector3.new(worldSize.X, worldSize.Y, 0.01)
    end

    RunService.RenderStepped:Connect(Update)
    Update()

    return {
        Frame = frame,
        Part = blurPart,
        SetVisibility = function(visible)
            blurPart.Transparency = visible and 0.98 or 1
        end
    }
end

