-- 1. UTILITIES MODULE
-- ==========================================
Modules.Utilities = (function()
    local Utils = {}
    
    function Utils:MakeDraggable(guiObject, speed)
        speed = speed or 0.12
        local dragging = false
        local dragInput, dragStart, startPos
        
        guiObject.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = guiObject.Position
                
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        
        guiObject.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                local targetPos = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X, 
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
                TweenService:Create(guiObject, TweenInfo.new(speed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
            end
        end)
    end
    
    function Utils:TrackConnection(tableRegistry, connection)
        table.insert(tableRegistry, connection)
        return connection
    end
    
    function Utils:CreateInstance(className, parent, name, props)
        local obj = Instance.new(className)
        obj.Name = name
        if props then
            for k, v in pairs(props) do obj[k] = v end
        end
        obj.Parent = parent
        return obj
    end
    
    return Utils
end)()

-- ==========================================
-- 2. ANIMATIONS MODULE
-- ==========================================
Modules.Animations = (function()
    local Anims = {}
    
    function Anims:ScaleIn(guiObject, duration, callback)
        duration = duration or 0.25
        local originalSize = guiObject.Size
        guiObject.Size = UDim2.new(0, 0, 0, 0)
        
        local anim = TweenService:Create(guiObject, TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = originalSize
        })
        anim:Play()
        if callback then anim.Completed:Connect(callback) end
    end
    
    function Anims:ScaleOut(guiObject, duration, callback)
        duration = duration or 0.25
        local anim = TweenService:Create(guiObject, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1
        })
        anim:Play()
        if callback then anim.Completed:Connect(callback) end
    end
    
    return Anims
end)()

