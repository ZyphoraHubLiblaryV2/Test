                selectedSet[opt] = not selectedSet[opt] or nil
                if selectedSet[opt] == nil then selectedSet[opt] = nil end
                local ok, err = pcall(callback, getSelectedList())
                if not ok then warn("[Nevora Hub] MultiDropdown callback error: " .. tostring(err)) end
