NevoraHub.__index = NevoraHub

-- [ TEMA & PALET WARNA ]
local Theme = {
    Background = Color3.fromRGB(15, 15, 18), -- Very Dark Charcoal
    Panel = Color3.fromRGB(24, 24, 28),      -- Slightly Lighter Dark Gray
    Accent = Color3.fromRGB(0, 208, 132),    -- Emerald Green
    TextPrimary = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(150, 150, 160),
    Border = Color3.fromRGB(35, 35, 40),
    Danger = Color3.fromRGB(255, 75, 75),
    Warning = Color3.fromRGB(255, 170, 0),
    Success = Color3.fromRGB(0, 208, 132)
}

-- [ UTILITAS ]
local function CreateTween(instance, info, properties)
    local tween = TweenService:Create(instance, TweenInfo.new(unpack(info)), properties)
    tween:Play()
    return tween
end

local function MakeDraggable(topbarobject, object)
    local dragging, dragInput, dragStart, startPos
    
    local function update(input)
        local delta = input.Position - dragStart
        CreateTween(object, {0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        })
    end
    
    topbarobject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = object.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    
    topbarobject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

-- [ CORE API ]
function NevoraHub.new(Config)
    local self = setmetatable({}, NevoraHub)
    
    self.Title = Config.Title or "Nevora Hub"
    self.Subtitle = Config.Subtitle or "Premium Interface"
    self.Accent = Config.Accent or Theme.Accent
    self.Size = Config.Size or UDim2.fromOffset(600, 450)
    self.Tabs = {}
    self.FirstTab = true
    
    -- Main GUI
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Nevora_" .. tostring(math.random(1000,9999))
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.Gui = ScreenGui
    
    -- Main Window
    local Window = Instance.new("Frame")
    Window.Name = "MainWindow"
    Window.Parent = ScreenGui
    Window.BackgroundColor3 = Theme.Background
    Window.Position = UDim2.new(0.5, -self.Size.X.Offset/2, 0.5, -self.Size.Y.Offset/2)
    Window.Size = self.Size
    Window.ClipsDescendants = false
    Window.AnchorPoint = Vector2.new(0.5, 0.5)
    Window.Position = UDim2.new(0.5, 0, 0.5, 0)
    
    -- Animasi Muncul (Fade + Scale)
    Window.Size = UDim2.new(0, self.Size.X.Offset - 50, 0, self.Size.Y.Offset - 50)
    Window.GroupTransparency = 1
    CreateTween(Window, {0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out}, {
        Size = self.Size,
        GroupTransparency = 0
    })

    local WindowCorner = Instance.new("UICorner")
    WindowCorner.CornerRadius = UDim.new(0, 8)
    WindowCorner.Parent = Window

    local WindowStroke = Instance.new("UIStroke")
    WindowStroke.Color = Theme.Border
    WindowStroke.Thickness = 1
    WindowStroke.Parent = Window
    
    -- Header & Drag
    local Header = Instance.new("Frame")
    Header.Name = "Header"
    Header.Parent = Window
    Header.BackgroundTransparency = 1
    Header.Size = UDim2.new(1, 0, 0, 50)
    MakeDraggable(Header, Window)
    
    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = Header
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Position = UDim2.new(0, 20, 0, 0)
    TitleLabel.Size = UDim2.new(0.5, 0, 1, 0)
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.Text = self.Title .. " <font color='rgb("..math.floor(Theme.TextSecondary.R*255)..","..math.floor(Theme.TextSecondary.G*255)..","..math.floor(Theme.TextSecondary.B*255)..")'>" .. self.Subtitle .. "</font>"
    TitleLabel.RichText = true
    TitleLabel.TextColor3 = Theme.TextPrimary
    TitleLabel.TextSize = 16
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- Layout Pembatas (Sidebar & Content)
    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Parent = Window
    Sidebar.BackgroundColor3 = Theme.Panel
    Sidebar.Position = UDim2.new(0, 15, 0, 60)
    Sidebar.Size = UDim2.new(0, 150, 1, -75)
    
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 6)
    
    local SidebarLayout = Instance.new("UIListLayout")
    SidebarLayout.Parent = Sidebar
    SidebarLayout.SortOrder = Enum.SortOrder.LayoutOrder
    SidebarLayout.Padding = UDim.new(0, 5)
    SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    local SidebarPadding = Instance.new("UIPadding")
    SidebarPadding.Parent = Sidebar
    SidebarPadding.PaddingTop = UDim.new(0, 10)

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Name = "ContentContainer"
    ContentContainer.Parent = Window
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Position = UDim2.new(0, 175, 0, 60)
    ContentContainer.Size = UDim2.new(1, -190, 1, -75)

    self.Sidebar = Sidebar
    self.Container = ContentContainer
    self.CurrentTab = nil

    return self
end

-- [ SISTEM TAB ]
function NevoraHub:CreateTab(Config)
    local TabName = Config.Name or "Tab"
    
    local TabButton = Instance.new("TextButton")
    TabButton.Parent = self.Sidebar
    TabButton.BackgroundColor3 = Theme.Background
    TabButton.BackgroundTransparency = 1
    TabButton.Size = UDim2.new(1, -16, 0, 32)
    TabButton.Font = Enum.Font.GothamMedium
    TabButton.Text = "  " .. TabName
    TabButton.TextColor3 = Theme.TextSecondary
    TabButton.TextSize = 13
    TabButton.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 6)
    
    local TabContent = Instance.new("ScrollingFrame")
    TabContent.Parent = self.Container
    TabContent.BackgroundTransparency = 1
    TabContent.Size = UDim2.new(1, 0, 1, 0)
    TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContent.ScrollBarThickness = 2
    TabContent.ScrollBarImageColor3 = Theme.Accent
    TabContent.Visible = false
    TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
    
    local ContentLayout = Instance.new("UIListLayout")
    ContentLayout.Parent = TabContent
    ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ContentLayout.Padding = UDim.new(0, 8)
    
    Instance.new("UIPadding", TabContent).PaddingRight = UDim.new(0, 5)

    local function ActivateTab()
        for _, tabInfo in ipairs(self.Tabs) do
            CreateTween(tabInfo.Button, {0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {
                BackgroundTransparency = 1,
                TextColor3 = Theme.TextSecondary
            })
            if tabInfo.Content.Visible then
                CreateTween(tabInfo.Content, {0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {GroupTransparency = 1})
                task.wait(0.1)
                tabInfo.Content.Visible = false
            end
        end
        
        CreateTween(TabButton, {0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {
            BackgroundTransparency = 0,
            TextColor3 = self.Accent
        })
        
        TabContent.Visible = true
        TabContent.GroupTransparency = 1
        CreateTween(TabContent, {0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {GroupTransparency = 0})
    end

    TabButton.MouseButton1Click:Connect(ActivateTab)
    table.insert(self.Tabs, {Button = TabButton, Content = TabContent})
    
    if self.FirstTab then
        ActivateTab()
        self.FirstTab = false
    end
    
    local TabObject = {Container = TabContent, Library = self}
    setmetatable(TabObject, self)
    return TabObject
end

