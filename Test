        BackgroundTransparency = 1,
        Parent = Holder,
    })
    Utility.Create("UIListLayout", {Padding = UDim.new(0, 4), Parent = OptionList})

    local function getSelectedList()
        local list = {}
        for opt in pairs(selectedSet) do table.insert(list, opt) end
        return list
    end

    local function rebuildOptions()
        for _, c in ipairs(OptionList:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _, opt in ipairs(options) do
            local isSel = selectedSet[opt] == true
            local OptBtn = Utility.Create("TextButton", {
                Text = (isSel and "✓ " or "") .. tostring(opt),
                Font = Enum.Font.Gotham,
