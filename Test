function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end

    -- Deactivate current tab
    if self.ActiveTab then
        self.ActiveTab.Content.Visible = false
        Utility:Tween(self.ActiveTab.Button, TweenInfo.new(0.3), {
            BackgroundTransparency = 1,
        })
        Utility:Tween(self.ActiveTab.NameLabel, TweenInfo.new(0.3), {
            TextColor3 = self.Theme.TextSecondary,
        })
        if self.ActiveTab.IconLabel then
            Utility:Tween(self.ActiveTab.IconLabel, TweenInfo.new(0.3), {
                ImageColor3 = self.Theme.TextSecondary,
            })
        end
    end

    -- Activate new tab
    self.ActiveTab = tab
    tab.Content.Visible = true

    Utility:Tween(tab.Button, TweenInfo.new(0.3), {
        BackgroundTransparency = 0.5,
        BackgroundColor3 = self.Theme.Accent,
    })
    Utility:Tween(tab.NameLabel, TweenInfo.new(0.3), {
        TextColor3 = self.Theme.TextPrimary,
    })
    if tab.IconLabel then
        Utility:Tween(tab.IconLabel, TweenInfo.new(0.3), {
            ImageColor3 = self.Theme.Accent,
        })
    end

    self.Signals.TabChanged:Fire(tab)
end

