        Utility.Tween(Holder, TweenInfo.new(0.25, EASE, DIR), {Size = UDim2.new(1, 0, 0, targetHeight)})
        Utility.Tween(Arrow, TweenInfo.new(0.2), {Rotation = open and 180 or 0})
    end)

    return {
        Get = getSelectedList,
        Set = function(list)
            selectedSet = {}
            for _, v in ipairs(list) do selectedSet[v] = true end
            rebuildOptions()
        end,
    }
end

