                    local idx = table.find(dropdown.Selected, val)
                    if idx then
                        table.remove(dropdown.Selected, idx)
                    else
                        table.insert(dropdown.Selected, val)
                    end
                    selectedLabel.Text = #dropdown.Selected .. " selected"
                else
                    dropdown.Selected = opt.Value or opt
                    selectedLabel.Text = opt.Label or tostring(opt)
                    dropdown:Close()
                end

                buildOptions()

                if dropdown.Callback then
                    dropdown.Callback(dropdown.Selected)
                end
            end)
        end
    end

    function dropdown:Open()
        if dropdown.Open then return end
        dropdown.Open = true
        menu.Visible = true
        buildOptions()

        local maxHeight = math.min(#dropdown.Options * 34 + 16, 200)
        Utility.Tween(menu, Constants.TweenInfo.Smooth, {
            Size = UDim2.new(1, 0, 0, maxHeight),
        })
        Utility.Tween(arrow, Constants.TweenInfo.Fast, {
            Rotation = 180,
        })
    end

    function dropdown:Close()
        if not dropdown.Open then return end
        dropdown.Open = false

        Utility.Tween(menu, Constants.TweenInfo.Fast, {
            Size = UDim2.new(1, 0, 0, 0),
        }, function()
            menu.Visible = false
        end)
        Utility.Tween(arrow, Constants.TweenInfo.Fast, {
            Rotation = 0,
        })
    end

    selectBtn.MouseButton1Click:Connect(function()
        if dropdown.Open then
            dropdown:Close()
        else
            dropdown:Open()
        end
    end)

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dropdown.Open then
            local pos = input.Position
            local absPos = menu.AbsolutePosition
            local absSize = menu.AbsoluteSize
            if pos.X < absPos.X or pos.X > absPos.X + absSize.X or 
               pos.Y < absPos.Y or pos.Y > absPos.Y + absSize.Y then
                local btnAbsPos = selectBtn.AbsolutePosition
                local btnAbsSize = selectBtn.AbsoluteSize
                if pos.X < btnAbsPos.X or pos.X > btnAbsPos.X + btnAbsSize.X or 
                   pos.Y < btnAbsPos.Y or pos.Y > btnAbsPos.Y + btnAbsSize.Y then
                    dropdown:Close()
                end
            end
        end
    end)

    dropdown.Instance = dropdownFrame
    dropdown.SetOptions = function(_, newOptions)
        dropdown.Options = newOptions
        if dropdown.Open then
            buildOptions()
        end
    end

    table.insert(self.Components, dropdown)
    return dropdown
end

