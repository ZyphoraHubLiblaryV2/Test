            dLbl.Text = desc
            dLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            dLbl.Font = Enum.Font.Gotham
            dLbl.TextSize = 12
            dLbl.TextXAlignment = Enum.TextXAlignment.Left
            dLbl.TextYAlignment = Enum.TextYAlignment.Top
            dLbl.TextWrapped = true
            
            return {
                Set = function(self, newTitle, newDesc)
                    tLbl.Text = newTitle
                    dLbl.Text = newDesc
                end
            }
        end
        
        -- ==========================================
        -- ELEMENT: COLOR PICKER
        -- ==========================================
        function Elements:AddColorPicker(text, defaultColor, callback, flag)
            local color = defaultColor or Color3.fromRGB(255, 255, 255)
            
            local cFrame = Instance.new("Frame", TabPage)
            cFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            cFrame.Size = UDim2.new(0, 400, 0, 34)
            cFrame.ClipsDescendants = true
            Instance.new("UICorner", cFrame).CornerRadius = UDim.new(0, 5)
            
            local tBtn = Instance.new("TextButton", cFrame)
            tBtn.Size = UDim2.new(1, 0, 0, 34)
            tBtn.BackgroundTransparency = 1
            tBtn.Text = "  " .. text
            tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            tBtn.Font = Enum.Font.Gotham
            tBtn.TextSize = 13
            tBtn.TextXAlignment = Enum.TextXAlignment.Left
            
            local displayColor = Instance.new("Frame", tBtn)
            displayColor.Size = UDim2.new(0, 25, 0, 25)
            displayColor.Position = UDim2.new(1, -35, 0, 4)
            displayColor.BackgroundColor3 = color
            Instance.new("UICorner", displayColor).CornerRadius = UDim.new(0, 4)
            
            local expanded = false
            local obj = {
                Color = color,
                Set = function(self, newColor)
                    self.Color = newColor
                    displayColor.BackgroundColor3 = newColor
                    pcall(callback, newColor)
                    if flag then flags[flag] = {R = newColor.R * 255, G = newColor.G * 255, B = newColor.B * 255} end
                    if configEnabled then Window:SaveConfig() end
                end
            }
            
            tBtn.MouseButton1Click:Connect(function()
                expanded = not expanded
                cFrame.Size = UDim2.new(0, 400, 0, expanded and 80 or 34)
            end)
            
            local rBox = Instance.new("TextBox", cFrame)
            rBox.Size = UDim2.new(0, 80, 0, 25)
            rBox.Position = UDim2.new(0, 10, 0, 40)
            rBox.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            rBox.Text = tostring(math.floor(color.R * 255))
            rBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            local gBox = Instance.new("TextBox", cFrame)
            gBox.Size = UDim2.new(0, 80, 0, 25)
            gBox.Position = UDim2.new(0, 100, 0, 40)
            gBox.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
            gBox.Text = tostring(math.floor(color.G * 255))
            gBox.TextColor3 = Color3.fromRGB(0, 0, 0)
            
            local bBox = Instance.new("TextBox", cFrame)
            bBox.Size = UDim2.new(0, 80, 0, 25)
            bBox.Position = UDim2.new(0, 190, 0, 40)
            bBox.BackgroundColor3 = Color3.fromRGB(50, 50, 255)
            bBox.Text = tostring(math.floor(color.B * 255))
            bBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            local applyBtn = Instance.new("TextButton", cFrame)
            applyBtn.Size = UDim2.new(0, 70, 0, 25)
            applyBtn.Position = UDim2.new(0, 280, 0, 40)
            applyBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            applyBtn.Text = "Apply"
            applyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            applyBtn.MouseButton1Click:Connect(function()
                local r = tonumber(rBox.Text) or 255
                local g = tonumber(gBox.Text) or 255
                local b = tonumber(bBox.Text) or 255
                obj:Set(Color3.fromRGB(r, g, b))
            end)
            
            if flag then flags[flag] = {R = color.R * 255, G = color.G * 255, B = color.B * 255} end
            return obj
        end
        
        -- ==========================================
        -- ELEMENT: LABEL
        -- ==========================================
        function Elements:AddLabel(text)
            local lbl = Instance.new("TextLabel", TabPage)
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0, 400, 0, 20)
            lbl.Text = text
            lbl.TextColor3 = Color3.fromRGB(150, 150, 160)
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 12
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            
            return {
                Set = function(self, newText)
                    lbl.Text = newText
                end
            }
        end
        
        -- ==========================================
        -- ELEMENT: DIVIDER
        -- ==========================================
        function Elements:AddDivider()
            local div = Instance.new("Frame", TabPage)
            div.Size = UDim2.new(0, 400, 0, 1)
            div.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
            return {
                Set = function(self, visible)
                    div.Visible = visible
                end
            }
        end
        
        return Elements
    end
    
    -- Auto-load config after 1 second
    task.delay(1, function()
        Window:LoadConfig()
    end)
    
    return Window
end

return NevoraHub
