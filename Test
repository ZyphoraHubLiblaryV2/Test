            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 13
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            
            local valLbl = Instance.new("TextLabel", sFrame)
            valLbl.BackgroundTransparency = 1
            valLbl.Position = UDim2.new(1, -60, 0, 5)
            valLbl.Size = UDim2.new(0, 50, 0, 20)
            valLbl.Text = tostring(current) .. (suffix or "")
            valLbl.TextColor3 = Color3.fromRGB(100, 150, 255)
            valLbl.Font = Enum.Font.GothamBold
            valLbl.TextSize = 13
            valLbl.TextXAlignment = Enum.TextXAlignment.Right
            
            local bar = Instance.new("TextButton", sFrame)
            bar.Size = UDim2.new(0, 380, 0, 8)
            bar.Position = UDim2.new(0, 10, 0, 32)
            bar.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
            bar.Text = ""
            Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)
            
            local fill = Instance.new("Frame", bar)
            fill.BackgroundColor3 = Color3.fromRGB(60, 100, 255)
            fill.Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
            Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 4)
            
            local dragging = false
            local obj = {
                Value = current,
                Set = function(self, val)
                    val = math.clamp(val, min, max)
                    current = val
                    self.Value = current
                    fill.Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
                    valLbl.Text = tostring(current) .. (suffix or "")
                    pcall(callback, current)
                    if flag then flags[flag] = current end
                    if configEnabled then Window:SaveConfig() end
                end
            }
            
            bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    local val = math.floor(min + (pos * (max - min)))
                    obj:Set(val)
                end
            end)
            
            if flag then flags[flag] = current end
            return obj
        end
        
        -- ==========================================
        -- ELEMENT: DROPDOWN
        -- ==========================================
        function Elements:AddDropdown(text, options, default, callback, flag, multi)
            local selected = default or {}
            if type(selected) ~= "table" then selected = {selected} end
            multi = multi or false
            
            local dFrame = Instance.new("Frame", TabPage)
            dFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            dFrame.Size = UDim2.new(0, 400, 0, 34)
            dFrame.ClipsDescendants = true
            Instance.new("UICorner", dFrame).CornerRadius = UDim.new(0, 5)
            
            local btn = Instance.new("TextButton", dFrame)
            btn.Size = UDim2.new(1, 0, 0, 34)
            btn.BackgroundTransparency = 1
            btn.Text = text .. " : [ " .. (selected[1] or "Select") .. " ]"
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 13
            btn.TextXAlignment = Enum.TextXAlignment.Left
            
            local expanded = false
            local obj = {
                Value = selected,
                Set = function(self, val)
                    if type(val) ~= "table" then val = {val} end
                    selected = val
                    self.Value = selected
                    local display = ""
                    for i, v in ipairs(selected) do
                        display = display .. v .. (i < #selected and ", " or "")
                    end
                    if display == "" then display = "None" end
                    btn.Text = text .. " : [ " .. display .. " ]"
                    pcall(callback, selected)
                    if flag then flags[flag] = selected end
                    if configEnabled then Window:SaveConfig() end
                end
            }
            
            btn.MouseButton1Click:Connect(function()
                expanded = not expanded
                local height = 34
                if expanded then
                    height = 34 + (#options * 28)
                end
                TweenService:Create(dFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 400, 0, height)}):Play()
            end)
            
            local optIndex = 0
            for _, opt in pairs(options) do
                optIndex = optIndex + 1
                local optBtn = Instance.new("TextButton", dFrame)
                optBtn.Size = UDim2.new(1, 0, 0, 28)
                optBtn.Position = UDim2.new(0, 0, 0, 34 + ((optIndex - 1) * 28))
                optBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
                optBtn.Text = tostring(opt)
                optBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 12
                local isSelected = false
                for _, s in ipairs(selected) do
                    if s == opt then isSelected = true end
                end
                if isSelected then
                    optBtn.BackgroundColor3 = Color3.fromRGB(60, 100, 200)
                end
                
                optBtn.MouseButton1Click:Connect(function()
                    if not multi then selected = {} end
                    local found = false
                    for i, s in ipairs(selected) do
                        if s == opt then
                            table.remove(selected, i)
                            found = true
                            break
                        end
                    end
                    if not found then
                        if not multi then selected = {} end
                        table.insert(selected, opt)
                    end
                    obj:Set(selected)
                    for _, child in pairs(dFrame:GetChildren()) do
                        if child:IsA("TextButton") and child ~= btn then
                            local isSel = false
                            for _, s in ipairs(selected) do
                                if s == child.Text then isSel = true end
                            end
                            child.BackgroundColor3 = isSel and Color3.fromRGB(60, 100, 200) or Color3.fromRGB(50, 50, 55)
                        end
                    end
                    if not multi then
                        expanded = false
                        dFrame.Size = UDim2.new(0, 400, 0, 34)
                    end
                end)
            end
            
            if flag then flags[flag] = selected end
            return obj
        end
        
