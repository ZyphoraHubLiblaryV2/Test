            local checkmark = Utility:Create("TextLabel", {
                Parent = optBtn,
                Size = UDim2.new(0, 20, 1, 0),
                Position = UDim2.new(1, -25, 0, 0),
                BackgroundTransparency = 1,
                Text = "✓",
                TextColor3 = Nevora.Theme.Accent,
                Font = Nevora.Theme.FontBold,
                TextSize = 14,
                TextTransparency = isSelected and 0 or 1
            })
            
            optBtn.MouseButton1Click:Connect(function()
                local index = table.find(self.Selected, option)
                if index then
                    table.remove(self.Selected, index)
                    Utility:Tween(optBtn, { BackgroundColor3 = Nevora.Theme.Background }, 0.2)
                    Utility:Tween(optText, { TextColor3 = Nevora.Theme.TextMuted }, 0.2)
                    Utility:Tween(checkmark, { TextTransparency = 1 }, 0.2)
                else
                    table.insert(self.Selected, option)
                    Utility:Tween(optBtn, { BackgroundColor3 = Nevora.Theme.Hover }, 0.2)
                    Utility:Tween(optText, { TextColor3 = Nevora.Theme.Accent }, 0.2)
                    Utility:Tween(checkmark, { TextTransparency = 0 }, 0.2)
                end
                
                self.SelectedLabel.Text = GetSelectedText()
                self.Callback(self.Selected)
            end)
            
            table.insert(OptionButtons, { Instance = optBtn })
        end
        self.Container.CanvasSize = UDim2.new(0, 0, 0, self.ListLayout.AbsoluteContentSize.Y)
    end
    
    self:Refresh(self.Options)
    return self
end

