        Size = UDim2.new(0, 10, 0, 10),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(self.Saturation, 0, 1 - self.Value, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    })
    Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = self.SVTracker })
    Utility:Create("UIStroke", { Color = Color3.fromRGB(0, 0, 0), Thickness = 1, Parent = self.SVTracker })
    
    self.HueMap = Utility:Create("ImageButton", {
        Parent = self.PickerContainer,
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -20, 0, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Image = "rbxassetid://3285244837",
        AutoButtonColor = false
    })
    Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = self.HueMap })
    
    self.HueTracker = Utility:Create("Frame", {
        Parent = self.HueMap,
        Size = UDim2.new(1, 2, 0, 6),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 1 - self.Hue, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    })
    Utility:Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = self.HueTracker })
    Utility:Create("UIStroke", { Color = Color3.fromRGB(0, 0, 0), Thickness = 1, Parent = self.HueTracker })
    
    self.MainButton.MouseButton1Click:Connect(function()
        self.IsOpen = not self.IsOpen
        local targetSize = self.IsOpen and UDim2.new(1, 0, 0, 175) or UDim2.new(1, 0, 0, 40)
        Utility:Tween(self.Instance, { Size = targetSize }, 0.3, Enum.EasingStyle.Quint)
        Utility:Tween(self.Stroke, { Color = self.IsOpen and Nevora.Theme.Accent or Nevora.Theme.Border }, 0.3)
    end)
    
    local function UpdateColor()
        local color = Color3.fromHSV(self.Hue, self.Saturation, self.Value)
        self.SVMap.BackgroundColor3 = Color3.fromHSV(self.Hue, 1, 1)
        self.ColorPreview.BackgroundColor3 = color
        self.Callback(color)
    end
    
    local isSVDragging = false
    self.SVMap.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isSVDragging = true
            local posX = math.clamp((input.Position.X - self.SVMap.AbsolutePosition.X) / self.SVMap.AbsoluteSize.X, 0, 1)
            local posY = math.clamp((input.Position.Y - self.SVMap.AbsolutePosition.Y) / self.SVMap.AbsoluteSize.Y, 0, 1)
            self.Saturation = posX
            self.Value = 1 - posY
            Utility:Tween(self.SVTracker, { Position = UDim2.new(posX, 0, posY, 0) }, 0.1)
            UpdateColor()
        end
    end)
    
    local isHueDragging = false
    self.HueMap.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isHueDragging = true
            local posY = math.clamp((input.Position.Y - self.HueMap.AbsolutePosition.Y) / self.HueMap.AbsoluteSize.Y, 0, 1)
            self.Hue = 1 - posY
            Utility:Tween(self.HueTracker, { Position = UDim2.new(0.5, 0, posY, 0) }, 0.1)
            UpdateColor()
        end
    end)
    
    GlobalConnections:Add("ColorPickerInputChanged_" .. config.Name, UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if isSVDragging then
                local posX = math.clamp((input.Position.X - self.SVMap.AbsolutePosition.X) / self.SVMap.AbsoluteSize.X, 0, 1)
                local posY = math.clamp((input.Position.Y - self.SVMap.AbsolutePosition.Y) / self.SVMap.AbsoluteSize.Y, 0, 1)
                self.Saturation = posX
                self.Value = 1 - posY
                Utility:Tween(self.SVTracker, { Position = UDim2.new(posX, 0, posY, 0) }, 0.05)
                UpdateColor()
            elseif isHueDragging then
                local posY = math.clamp((input.Position.Y - self.HueMap.AbsolutePosition.Y) / self.HueMap.AbsoluteSize.Y, 0, 1)
                self.Hue = 1 - posY
                Utility:Tween(self.HueTracker, { Position = UDim2.new(0.5, 0, posY, 0) }, 0.05)
                UpdateColor()
            end
        end
    end))
    
    GlobalConnections:Add("ColorPickerInputEnded_" .. config.Name, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isSVDragging = false
            isHueDragging = false
        end
    end))
    
    return self
end

