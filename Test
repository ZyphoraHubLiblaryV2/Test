    })
    
    CreateInstance("UICorner", {
        Parent = button,
        CornerRadius = UDim.new(0, 6)
    })
    
    -- Description
    if config.Description then
        CreateInstance("TextLabel", {
            Parent = section.ItemsContainer,
            BackgroundTransparency = 1,
            Font = Enum.Font.Gotham,
            Text = config.Description,
            TextColor3 = DEFAULT_SUBTEXT,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Size = UDim2.new(1, 0, 0, 20),
            LayoutOrder = button.LayoutOrder + 1
        })
    end
    
    -- Button effects
    button.MouseEnter:Connect(function()
        ApplyTween(button, TweenInfo.new(0.2), {
            BackgroundColor3 = tab.Library.Accent:lerp(Color3.fromRGB(255, 255, 255), 0.1)
        })
    end)
    
    button.MouseLeave:Connect(function()
        ApplyTween(button, TweenInfo.new(0.2), {
            BackgroundColor3 = tab.Library.Accent
        })
    end)
    
    button.MouseButton1Down:Connect(function()
        ApplyTween(button, TweenInfo.new(0.1), {
            Size = UDim2.new(0.95, 0, 0.95, 0)
        })
        
        -- Ripple effect
        local ripple = CreateInstance("Frame", {
            Parent = button,
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(0, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            ZIndex = 5
        })
        
        CreateInstance("UICorner", {
            Parent = ripple,
            CornerRadius = UDim.new(1, 0)
        })
        
        ApplyTween(ripple, TweenInfo.new(0.4), {
            Size = UDim2.fromOffset(100, 100),
            BackgroundTransparency = 1
        })
        
        delay(0.4, function()
            ripple:Destroy()
        end)
    end)
    
    button.MouseButton1Up:Connect(function()
        ApplyTween(button, TweenInfo.new(0.1), {
            Size = UDim2.new(1, 0, 1, 0)
        })
    end)
    
    if config.Callback then
        button.MouseButton1Click:Connect(function()
            config.Callback()
        end)
    end
end

