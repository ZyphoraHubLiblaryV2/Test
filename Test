-- MAID / CLEANUP MANAGER
-- ═══════════════════════════════════════════════════════════════

local Maid = {}
Maid.__index = Maid

function Maid.new()
    local self = setmetatable({}, Maid)
    self.Tasks = {}
    return self
end

function Maid:GiveTask(task)
    table.insert(self.Tasks, task)
    return task
end

function Maid:GiveTasks(...)
    for _, task in ipairs({...}) do
        self:GiveTask(task)
    end
end

function Maid:Clean()
    for _, task in ipairs(self.Tasks) do
        if typeof(task) == "RBXScriptConnection" then
            task:Disconnect()
        elseif typeof(task) == "Instance" then
            task:Destroy()
        elseif type(task) == "function" then
            task()
        elseif task and task.Destroy then
            task:Destroy()
        elseif task and task.Disconnect then
            task:Disconnect()
        end
    end
    self.Tasks = {}
end

function Maid:Destroy()
    self:Clean()
end

