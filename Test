function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end

    if self.ActiveTab then
        Utility.Tween(self.ActiveTab.Button, Constants.TweenInfo.Fast, {
            BackgroundTransparency = 1,
        })
        if self.ActiveTab.IconLabel then
            Utility.Tween(self.ActiveTab.IconLabel, Constants.TweenInfo.Fast, {
                ImageColor3 = Constants.TextSecondary,
            })
        end
        Utility.Tween(self.ActiveTab.Label, Constants.TweenInfo.Fast, {
            TextColor3 = Constants.TextSecondary,
        })

        Utility.Tween(self.ActiveTab.Content, Constants.TweenInfo.Fast, {
            Position = UDim2.new(0.02, 0, 0, 0),
            BackgroundTransparency = 1,
        }, function()
            self.ActiveTab.Content.Visible = false
        end)
    end

    self.ActiveTab = tab
    tab.Content.Visible = true
    tab.Content.Position = UDim2.new(0.02, 0, 0, 0)

    Utility.Tween(tab.Button, Constants.TweenInfo.Fast, {
        BackgroundTransparency = 0.5,
    })
    if tab.IconLabel then
        Utility.Tween(tab.IconLabel, Constants.TweenInfo.Fast, {
            ImageColor3 = Constants.Accent,
        })
    end
    Utility.Tween(tab.Label, Constants.TweenInfo.Fast, {
        TextColor3 = Constants.Accent,
    })

    Utility.Tween(tab.Content, Constants.TweenInfo.Smooth, {
        Position = UDim2.new(0, 0, 0, 0),
    })
end

function Window:Minimize()
    if self.Minimized then
        Utility.Tween(self.MainFrame, Constants.TweenInfo.Smooth, {
            Size = self.PreviousSize or UDim2.new(0, 900, 0, 600),
        })
        self.ContentArea.Visible = true
        self.Sidebar.Visible = true
        self.Minimized = false
    else
        self.PreviousSize = self.MainFrame.Size
        Utility.Tween(self.MainFrame, Constants.TweenInfo.Smooth, {
            Size = UDim2.new(0, 220, 0, 45),
        })
        self.ContentArea.Visible = false
        self.Sidebar.Visible = false
        self.Minimized = true
    end
end

function Window:Maximize()
    if self.Maximized then
        Utility.Tween(self.MainFrame, Constants.TweenInfo.Smooth, {
            Size = self.PreviousSize or UDim2.new(0, 900, 0, 600),
            Position = self.PreviousPosition or UDim2.new(0.5, -450, 0.5, -300),
        })
        self.Maximized = false
    else
        self.PreviousSize = self.MainFrame.Size
        self.PreviousPosition = self.MainFrame.Position
        Utility.Tween(self.MainFrame, Constants.TweenInfo.Smooth, {
            Size = UDim2.new(1, -20, 1, -20),
            Position = UDim2.new(0, 10, 0, 10),
        })
        self.Maximized = true
    end
end

function Window:Close()
    Utility.Tween(self.MainFrame, Constants.TweenInfo.Smooth, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
    }, function()
        self.Gui:Destroy()
        self.Maid:Destroy()
    end)
end

function Window:Fullscreen()
    if self.Fullscreen then
        self:Maximize()
        self.Fullscreen = false
    else
        self.PreviousSize = self.MainFrame.Size
        self.PreviousPosition = self.MainFrame.Position
        self.MainFrame.Size = UDim2.new(1, 0, 1, 0)
        self.MainFrame.Position = UDim2.new(0, 0, 0, 0)
        self.Fullscreen = true
    end
end

function Window:SetTransparency(transparency)
    self.MainFrame.BackgroundTransparency = transparency
end

function Window:Destroy()
    self.Maid:Destroy()
    self.Gui:Destroy()
end

