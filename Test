--// ================= DRAGGING =================
function NevoraHub:_MakeDraggable(dragHandle, target)
    local dragging, dragStart, startPos = false, nil, nil

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

--// ================= MINIMIZE =================
function NevoraHub:_ToggleMinimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Utility.Tween(self.Main, TweenInfo.new(0.3, EASE, DIR), {Size = UDim2.new(self.Size.X.Scale, self.Size.X.Offset, 0, 46)})
    else
        Utility.Tween(self.Main, TweenInfo.new(0.3, EASE, DIR), {Size = self.Size})
    end
end

function NevoraHub:ToggleVisible()
    self.Visible = not self.Visible
    if self.Visible then
        self.Main.Visible = true
        Utility.Tween(self.Main, TweenInfo.new(0.25, EASE, DIR), {BackgroundTransparency = 0})
    else
        local tw = Utility.Tween(self.Main, TweenInfo.new(0.2, EASE, DIR), {BackgroundTransparency = 1})
        tw.Completed:Connect(function()
            if not self.Visible then
                self.Main.Visible = false
            end
        end)
    end
end

function NevoraHub:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

function NevoraHub:UpdateTitle(title, subtitle)
    if title then
        self.Title = title
        self.TitleLabel.Text = title
    end
    if subtitle then
        self.Subtitle = subtitle
        self.SubtitleLabel.Text = subtitle
    end
end

function NevoraHub:SetWatermark(text)
    if text and text ~= "" then
        self.Watermark.Text = text
        self.Watermark.Visible = true
    else
        self.Watermark.Visible = false
    end
end

function NevoraHub:SetTheme(themeName)
    local newTheme = Themes[themeName]
    if not newTheme then return end
    self.Theme = newTheme
    -- Basic re-color of core frames; component-level recoloring can be extended similarly.
    self.Main.BackgroundColor3 = newTheme.Background
    self.Sidebar.BackgroundColor3 = newTheme.Panel
    self.ContentHolder.BackgroundColor3 = newTheme.Panel
end

--// ================= NOTIFICATIONS =================
function NevoraHub:Notify(config)
    config = config or {}
    local Theme = self.Theme
    local title = config.Title or "Notification"
    local content = config.Content or ""
    local duration = config.Duration or 4
    local status = config.Type or "info" -- info, success, warning, danger

    local colorMap = {
        info = Theme.Accent,
        success = Theme.Success,
        warning = Theme.Warning,
        danger = Theme.Danger,
    }
    local barColor = colorMap[status] or Theme.Accent

    local Notif = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Theme.Panel,
        BackgroundTransparency = 1,
        Parent = self.NotifyHolder,
    })
    Utility.Corner(Notif, 8)
    Utility.Stroke(Notif, Theme.Stroke, 1)
    Utility.Padding(Notif, 10)

    local Bar = Utility.Create("Frame", {
        Size = UDim2.new(0, 3, 1, -4),
        Position = UDim2.new(0, 0, 0, 2),
        BackgroundColor3 = barColor,
        Parent = Notif,
    })
    Utility.Corner(Bar, 2)

    local TitleLbl = Utility.Create("TextLabel", {
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -12, 0, 18),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Notif,
    })

    local ContentLbl = Utility.Create("TextLabel", {
        Text = content,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 20),
        Size = UDim2.new(1, -12, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Notif,
    })

    -- fade/slide in
    Notif.Position = UDim2.new(1, 40, 0, 0)
    Utility.Tween(Notif, TweenInfo.new(0.3, EASE, DIR), {BackgroundTransparency = 0.05})

    task.delay(duration, function()
        if Notif and Notif.Parent then
            local tw = Utility.Tween(Notif, TweenInfo.new(0.25, EASE, DIR), {BackgroundTransparency = 1})
            tw.Completed:Connect(function()
                Notif:Destroy()
            end)
        end
    end)
end

--// ================= CONFIG SAVE/LOAD =================
function NevoraHub:SaveConfig()
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(self.FlagValues)
    end)
    if ok and writefile then
        pcall(function()
            writefile(self.ConfigName .. ".json", encoded)
        end)
    end
end

function NevoraHub:LoadConfig()
    if not (readfile and isfile) then return end
    local ok, exists = pcall(isfile, self.ConfigName .. ".json")
    if ok and exists then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(self.ConfigName .. ".json"))
        end)
        if success and type(data) == "table" then
            self.FlagValues = data
        end
    end
end

--// ================= TAB =================
local Tab = {}
Tab.__index = Tab

function NevoraHub:CreateTab(config)
    config = config or {}
    local Theme = self.Theme

    local TabButton = Utility.Create("TextButton", {
        Text = "  " .. (config.Name or "Tab"),
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundColor3 = Theme.PanelLight,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        Parent = self.Sidebar,
    })
    Utility.Corner(TabButton, 6)

    local Page = Utility.Create("ScrollingFrame", {
        Size = UDim2.new(1, -16, 1, -16),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = self.ContentHolder,
    })
    local PageList = Utility.Create("UIListLayout", {
        Padding = UDim.new(0, 10),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = Page,
    })

    local self_tab = setmetatable({
        Hub = self,
        Button = TabButton,
        Page = Page,
        Name = config.Name or "Tab",
    }, Tab)

    table.insert(self.Tabs, self_tab)

    TabButton.MouseButton1Click:Connect(function()
        self:_SelectTab(self_tab)
    end)

    TabButton.MouseEnter:Connect(function()
        if not Page.Visible then
            Utility.Tween(TabButton, TweenInfo.new(0.15), {BackgroundTransparency = 0.7})
        end
    end)
    TabButton.MouseLeave:Connect(function()
        if not Page.Visible then
            Utility.Tween(TabButton, TweenInfo.new(0.15), {BackgroundTransparency = 1})
        end
    end)

    -- first tab auto selected
    if #self.Tabs == 1 then
        self:_SelectTab(self_tab)
    end

    return self_tab
end

function NevoraHub:_SelectTab(selected)
    local Theme = self.Theme
    for _, tab in ipairs(self.Tabs) do
        local isSel = (tab == selected)
        tab.Page.Visible = isSel
        Utility.Tween(tab.Button, TweenInfo.new(0.2), {
            BackgroundTransparency = isSel and 0 or 1,
            TextColor3 = isSel and Theme.Text or Theme.SubText,
        })
        tab.Button.BackgroundColor3 = Theme.Accent
        if isSel then
            tab.Page.Position = UDim2.new(0, 20, 0, 8)
            Utility.Tween(tab.Page, TweenInfo.new(0.25, EASE, DIR), {Position = UDim2.new(0, 8, 0, 8)})
        end
    end
end

