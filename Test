    -- Configuration System
    function Window:EnableConfig(fileName)
        configEnabled = true
        configFileName = fileName or "NevoraConfig"
        if not isfolder("NevoraHub") then makefolder("NevoraHub") end
        if not isfolder("NevoraHub/Configs") then makefolder("NevoraHub/Configs") end
    end

    function Window:SaveConfig()
        if not configEnabled then return end
        local data = {}
        for flag, value in pairs(flags) do
            if type(value) == "table" then
                -- Handle table values (like color picker)
                data[flag] = value
            else
                data[flag] = value
            end
        end
        -- Save window position and size
        data._window = {
            Position = {X = MainFrame.Position.X.Scale, Y = MainFrame.Position.Y.Scale},
            Size = {X = MainFrame.Size.X.Offset, Y = MainFrame.Size.Y.Offset}
        }
        local path = "NevoraHub/Configs/" .. configFileName .. ".json"
        if writefile then
            local success, err = pcall(function()
                writefile(path, HttpService:JSONEncode(data))
            end)
            if success then
                NevoraHub:Notify({Title = "Config Saved", Content = "Configuration saved successfully", Duration = 2})
            else
                warn("Failed to save config:", err)
            end
        end
    end

    function Window:LoadConfig()
        if not configEnabled then return end
        local path = "NevoraHub/Configs/" .. configFileName .. ".json"
        if isfile and isfile(path) then
            local success, data = pcall(function()
                return HttpService:JSONDecode(readfile(path))
            end)
            if success and data then
                for flag, value in pairs(data) do
                    if flag ~= "_window" and flags[flag] and flags[flag].Set then
                        flags[flag]:Set(value)
                    end
                end
                -- Load window position
                if data._window then
                    MainFrame.Position = UDim2.new(data._window.Position.X, 0, data._window.Position.Y, 0)
                end
                NevoraHub:Notify({Title = "Config Loaded", Content = "Configuration loaded successfully", Duration = 2})
            end
        end
    end

    function Window:AutoSaveConfig(interval)
        autoSaveEnabled = true
        interval = interval or 30
        if autoSaveInterval then
            task.cancel(autoSaveInterval)
        end
        autoSaveInterval = task.spawn(function()
            while autoSaveEnabled do
                task.wait(interval)
                Window:SaveConfig()
            end
        end)
    end

    -- Theme Management
    function Window:ModifyTheme(themeName)
        if Themes[themeName] then
            currentTheme = Themes[themeName]
            -- Update all UI elements
            MainFrame.BackgroundColor3 = currentTheme.Background
            Border.BackgroundColor3 = currentTheme.WindowBorder
            Topbar.BackgroundColor3 = currentTheme.Topbar
            TopbarCorner.BackgroundColor3 = currentTheme.Topbar
            Shadow.ImageColor3 = currentTheme.Shadow
            TitleLabel.TextColor3 = currentTheme.TextColor
            Sidebar.BackgroundColor3 = currentTheme.SidebarBackground
            MainContent.BackgroundColor3 = currentTheme.Background
            MainContent.ScrollBarImageColor3 = currentTheme.ScrollbarColor
            
            for _, btn in pairs(Topbar:GetChildren()) do
                if btn:IsA("TextButton") then
                    btn.TextColor3 = currentTheme.TextColor
                end
            end
            
            -- Update tabs
            for _, tab in pairs(tabs) do
                tab.button.BackgroundColor3 = currentTheme.TabBackground
                tab.button.TextColor3 = currentTheme.TabTextColor
                if tab.button:FindFirstChild("ImageLabel") then
                    tab.button.ImageLabel.ImageColor3 = currentTheme.TabTextColor
                end
            end
            if currentTab and tabs[currentTab] then
                tabs[currentTab].button.BackgroundColor3 = currentTheme.TabBackgroundSelected
                tabs[currentTab].button.TextColor3 = currentTheme.SelectedTabTextColor
                if tabs[currentTab].button:FindFirstChild("ImageLabel") then
                    tabs[currentTab].button.ImageLabel.ImageColor3 = currentTheme.SelectedTabTextColor
                end
            end
            
            -- Update notification container
            NotifyContainer.BackgroundColor3 = currentTheme.NotificationBackground
            
            NevoraHub:Notify({Title = "Theme Changed", Content = "Changed to " .. themeName, Duration = 2})
        end
    end

