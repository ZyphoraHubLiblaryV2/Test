function Tab:CreateSlider(config)
    config = config or {}
    local Theme = self.Hub.Theme
    local min = config.Min or 0
    local max = config.Max or 100
    local default = math.clamp(config.Default or min, min, max)
    local callback = config.Callback or function() end

    local Holder = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 46),
        BackgroundColor3 = Theme.PanelLight,
        Parent = self.Page,
    })
    Utility.Corner(Holder, 8)

    Utility.Create("TextLabel", {
        Text = config.Name or "Slider",
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 6),
        Size = UDim2.new(1, -70, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })

    local ValueLabel = Utility.Create("TextLabel", {
        Text = tostring(default),
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -60, 0, 6),
        Size = UDim2.new(0, 50, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = Holder,
    })

    local Bar = Utility.Create("Frame", {
        Size = UDim2.new(1, -24, 0, 6),
        Position = UDim2.new(0, 12, 0, 30),
        BackgroundColor3 = Theme.Stroke,
        Parent = Holder,
    })
    Utility.Corner(Bar, 999)

    local Fill = Utility.Create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        Parent = Bar,
    })
    Utility.Corner(Fill, 999)

    local dragging = false
    local function updateFromInputX(xPos)
        local relative = math.clamp((xPos - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * relative + 0.5)
        Fill.Size = UDim2.new(relative, 0, 1, 0)
        ValueLabel.Text = tostring(value)
        local ok, err = pcall(callback, value)
        if not ok then warn("[Nevora Hub] Slider callback error: " .. tostring(err)) end
        return value
    end

    Bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateFromInputX(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateFromInputX(input.Position.X)
        end
    end)

    return {
        Set = function(value)
            value = math.clamp(value, min, max)
            local relative = (value - min) / (max - min)
            Fill.Size = UDim2.new(relative, 0, 1, 0)
            ValueLabel.Text = tostring(value)
        end
    }
end

