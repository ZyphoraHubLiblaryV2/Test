            expandIcon.Text = "▾"
            expandIcon.TextColor3 = currentTheme.TextColor
            expandIcon.TextSize = 16
            expandIcon.Font = Enum.Font.Gotham

            local expanded = false
            local optionsContainer = Instance.new("Frame")
            optionsContainer.Parent = container
            optionsContainer.BackgroundTransparency = 1
            optionsContainer.Size = UDim2.new(1, 0, 0, 0)
            optionsContainer.Position = UDim2.new(0, 0, 0, 36)
            optionsContainer.ClipsDescendants = true

            local optLayout = Instance.new("UIListLayout")
            optLayout.Parent = optionsContainer
            optLayout.Padding = UDim.new(0, 2)

            local obj = {
                Value = currentOption,
                Set = function(self, val)
                    if type(val) ~= "table" then val = {val} end
                    currentOption = val
                    self.Value = currentOption
                    local display = ""
                    for i, v in ipairs(currentOption) do
                        display = display .. v .. (i < #currentOption and ", " or "")
                    end
                    if display == "" then display = "None"
                    displayLabel.Text = display
                    pcall(settings.Callback, currentOption)
                    if settings.Flag then flags[settings.Flag] = currentOption end
                    if configEnabled then Window:SaveConfig() end
                end
            }

            for _, opt in pairs(options) do
                local optBtn = Instance.new("TextButton")
                optBtn.Parent = optionsContainer
                optBtn.Size = UDim2.new(1, 0, 0, 30)
                optBtn.BackgroundColor3 = currentTheme.DropdownUnselected
                optBtn.Text = "  " .. tostring(opt)
                optBtn.TextColor3 = currentTheme.TextColor
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 13
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 4)

                local isSelected = false
                for _, s in ipairs(currentOption) do
                    if s == opt then isSelected = true end
                end
                if isSelected then
                    optBtn.BackgroundColor3 = currentTheme.DropdownSelected
                end

                optBtn.MouseButton1Click:Connect(function()
                    if not multi then currentOption = {} end
                    local found = false
                    for i, s in ipairs(currentOption) do
                        if s == opt then
                            table.remove(currentOption, i)
                            found = true
                            break
                        end
                    end
                    if not found then
                        if not multi then currentOption = {} end
                        table.insert(currentOption, opt)
                    end
                    obj:Set(currentOption)
                    
                    for _, child in pairs(optionsContainer:GetChildren()) do
                        if child:IsA("TextButton") then
                            local isSel = false
                            for _, s in ipairs(currentOption) do
                                if s == child.Text:gsub("^%s*(.-)%s*$", "%1") then isSel = true end
                            end
                            child.BackgroundColor3 = isSel and currentTheme.DropdownSelected or currentTheme.DropdownUnselected
                        end
                    end
                    
                    if not multi then
                        expanded = false
                        TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                        TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 36)}):Play()
                        expandIcon.Text = "▾"
                    end
                end)
            end

            container.MouseButton1Click:Connect(function()
                expanded = not expanded
                if expanded then
                    local totalHeight = #options * 32 + 4
                    TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, totalHeight)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 36 + totalHeight)}):Play()
                    expandIcon.Text = "▴"
                else
                    TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 36)}):Play()
                    expandIcon.Text = "▾"
                end
            end)

            if settings.Flag then flags[settings.Flag] = currentOption end
            return obj
        end

