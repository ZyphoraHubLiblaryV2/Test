local notificationQueue = {}
local isNotifying = false

function NevoraHub:Notify(data)
    data = data or {}
    local title = data.Title or "Notification"
    local content = data.Content or ""
    local duration = data.Duration or 3
    local image = data.Image or ""
    
    table.insert(notificationQueue, {title = title, content = content, duration = duration, image = image})
    
    if not isNotifying then
        isNotifying = true
        task.spawn(function()
            while #notificationQueue > 0 do
                local notif = table.remove(notificationQueue, 1)
                local success, err = pcall(function()
                    NevoraHub:ShowNotification(notif.title, notif.content, notif.duration, notif.image)
                end)
                if not success then
                    warn("Notification error:", err)
                end
                task.wait(0.2)
            end
            isNotifying = false
        end)
    end
end

