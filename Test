function Tab:CreateKeybind(config)
    config = config or {}
    local Theme = self.Hub.Theme
    local currentKey = config.Default or Enum.KeyCode.Unknown
    local callback = config.Callback or function() end
    local mode = config.Mode or "Toggle" -- "Toggle" or "Hold"
    local binding = false

    local Holder = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Theme.PanelLight,
        Parent = self.Page,
    })
    Utility.Corner(Holder, 8)

    Utility.Create("TextLabel", {
        Text = config.Name or "Keybind",
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.5, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })

    local KeyBtn = Utility.Create("TextButton", {
        Text = currentKey.Name,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Theme.Accent,
        BackgroundColor3 = Theme.Panel,
        Size = UDim2.new(0, 90, 0, 24),
        Position = UDim2.new(1, -100, 0.5, -12),
        Parent = Holder,
    })
    Utility.Corner(KeyBtn, 6)

    KeyBtn.MouseButton1Click:Connect(function()
        binding = true
        KeyBtn.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if binding and input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            KeyBtn.Text = currentKey.Name
            binding = false
            return
        end
        if not gameProcessed and input.KeyCode == currentKey then
            if mode == "Hold" then
                local ok, err = pcall(callback, true)
                if not ok then warn("[Nevora Hub] Keybind callback error: " .. tostring(err)) end
            else
                local ok, err = pcall(callback)
                if not ok then warn("[Nevora Hub] Keybind callback error: " .. tostring(err)) end
            end
        end
    end)

    if mode == "Hold" then
        UserInputService.InputEnded:Connect(function(input, gameProcessed)
            if not gameProcessed and input.KeyCode == currentKey then
                local ok, err = pcall(callback, false)
                if not ok then warn("[Nevora Hub] Keybind callback error: " .. tostring(err)) end
            end
        end)
    end

    return {
        Set = function(keyCode) currentKey = keyCode; KeyBtn.Text = keyCode.Name end,
    }
end

