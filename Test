--// ================= UTILITIES =================
local Utility = {}

function Utility.Create(class, props, children)
    local inst = Instance.new(class)
    for prop, value in pairs(props or {}) do
        inst[prop] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

function Utility.Tween(obj, info, props)
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

function Utility.Corner(parent, radius)
    return Utility.Create("UICorner", {CornerRadius = UDim.new(0, radius or 8), Parent = parent})
end

function Utility.Stroke(parent, color, thickness)
    return Utility.Create("UIStroke", {
        Color = color,
        Thickness = thickness or 1,
        Transparency = 0.4,
        Parent = parent,
    })
end

function Utility.Padding(parent, all)
    return Utility.Create("UIPadding", {
        PaddingTop = UDim.new(0, all),
        PaddingBottom = UDim.new(0, all),
        PaddingLeft = UDim.new(0, all),
        PaddingRight = UDim.new(0, all),
        Parent = parent,
    })
end

local EASE = Enum.EasingStyle.Quint
local DIR = Enum.EasingDirection.Out

--// ================= LIBRARY CORE =================
local NevoraHub = {}
NevoraHub.__index = NevoraHub

function NevoraHub.new(config)
    config = config or {}
    local self = setmetatable({}, NevoraHub)

    self.Title = config.Title or "Nevora Hub"
    self.Subtitle = config.Subtitle or "Premium Interface"
    self.Size = config.Size or UDim2.fromOffset(600, 450)
    self.ConfigName = config.ConfigName or "NevoraHubConfig"
    self.SaveConfigEnabled = config.SaveConfig or false
    self.Theme = Themes[config.Theme or "Dark"]
    if config.Accent then
        self.Theme.Accent = config.Accent
    end

    self.Tabs = {}
    self.FlagValues = {}
    self.Flags = {}
    self.Visible = true
    self.Minimized = false

    self:_BuildUI()
    if self.SaveConfigEnabled then
        self:LoadConfig()
    end

    return self
end

