-- COMPONENT: PERFORMANCE GRAPH
-- ═══════════════════════════════════════════════════════════════

function Section:CreatePerformanceGraph(options)
    options = options or {}
    local graph = {}
    graph.Data = {}
    graph.MaxPoints = options.MaxPoints or 60
    graph.MaxValue = options.MaxValue or 60

    local graphFrame = Utility.Create("Frame", {
        Name = options.Name or "PerformanceGraph",
        Size = options.Size or UDim2.new(1, 0, 0, 150),
        BackgroundColor3 = Constants.Card,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        Parent = self.ComponentContainer,
    })

    local graphCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 10),
        Parent = graphFrame,
    })

    local graphStroke = Utility.Create("UIStroke", {
        Color = Constants.Border,
        Thickness = 1,
        Transparency = 0.4,
        Parent = graphFrame,
    })

    local title = Utility.Create("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, 0, 0, 24),
        Position = UDim2.new(0, 12, 0, 4),
        BackgroundTransparency = 1,
        Text = options.Title or "Performance",
        TextColor3 = Constants.TextPrimary,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = graphFrame,
    })

    local canvas = Utility.Create("Frame", {
        Name = "Canvas",
        Size = UDim2.new(1, -24, 1, -40),
        Position = UDim2.new(0, 12, 0, 32),
        BackgroundTransparency = 1,
        Parent = graphFrame,
    })

    local gridLines = Utility.Create("Frame", {
        Name = "Grid",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Parent = canvas,
    })

    -- Create grid lines
    for i = 1, 4 do
        local line = Utility.Create("Frame", {
            Name = "GridLine" .. i,
            Size = UDim2.new(1, 0, 0, 1),
            Position = UDim2.new(0, 0, i / 5, 0),
            BackgroundColor3 = Constants.Border,
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            Parent = gridLines,
        })
    end

    local lineFrame = Utility.Create("Frame", {
        Name = "Line",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Parent = canvas,
    })

    function graph:AddPoint(value)
        table.insert(graph.Data, value)
        if #graph.Data > graph.MaxPoints then
            table.remove(graph.Data, 1)
        end

        -- Clear old line
        for _, child in ipairs(lineFrame:GetChildren()) do
            child:Destroy()
        end

        -- Draw new line
        if #graph.Data < 2 then return end

        local width = lineFrame.AbsoluteSize.X
        local height = lineFrame.AbsoluteSize.Y
        local stepX = width / (graph.MaxPoints - 1)

        for i = 2, #graph.Data do
            local x1 = (i - 2) * stepX
            local x2 = (i - 1) * stepX
            local y1 = height - (graph.Data[i - 1] / graph.MaxValue) * height
            local y2 = height - (graph.Data[i] / graph.MaxValue) * height

            local lineLength = math.sqrt((x2 - x1)^2 + (y2 - y1)^2)
            local angle = math.atan2(y2 - y1, x2 - x1)

            local line = Utility.Create("Frame", {
                Name = "Segment" .. i,
                Size = UDim2.new(0, lineLength, 0, 2),
                Position = UDim2.new(0, x1, 0, y1),
                BackgroundColor3 = options.Color or Constants.Accent,
                BorderSizePixel = 0,
                Rotation = math.deg(angle),
                Parent = lineFrame,
            })
        end
    end

    graph.Instance = graphFrame

    table.insert(self.Components, graph)
    return graph
end

