function Window:CreateConsole(section, config)
    config = config or {}
    local console = {}

    console.MaxLines = config.MaxLines or 100
    console.Lines = {}

    local container = Utility:Create("Frame", {
        Name = "Console",
        BackgroundColor3 = self.Theme.Secondary,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 200),
        Parent = section.Components,
    })

    local corner = Utility:Create("UICorner", {
        CornerRadius = UDim.new(0, 10),
        Parent = container,
    })

    local scrollFrame = Utility:Create("ScrollingFrame", {
        Name = "Scroll",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 10, 0, 10),
        Size = UDim2.new(1, -20, 1, -20),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = self.Theme.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        Parent = container,
    })

    local layout = Utility:Create("UIListLayout", {
        Padding = UDim.new(0, 2),
        Parent = scrollFrame,
    })

    console.Log = function(message, type)
        type = type or "Info"
        local colors = {
            Info = self.Theme.TextPrimary,
            Success = self.Theme.Success,
            Warning = self.Theme.Warning,
            Error = self.Theme.Error,
        }

        local line = Utility:Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 18),
            Font = Enum.Font.Code,
            Text = "[" .. os.date("%H:%M:%S") .. "] " .. message,
            TextColor3 = colors[type] or self.Theme.TextPrimary,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = scrollFrame,
        })

        table.insert(console.Lines, line)

        if #console.Lines > console.MaxLines then
            console.Lines[1]:Destroy()
            table.remove(console.Lines, 1)
        end

        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y)
        scrollFrame.CanvasPosition = Vector2.new(0, layout.AbsoluteContentSize.Y)
    end

    console.Clear = function()
        for _, line in ipairs(console.Lines) do
            line:Destroy()
        end
        console.Lines = {}
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    end

    console.Instance = container
    return console
end

