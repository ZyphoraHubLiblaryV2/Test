        Text = "✕",
        TextColor3 = Color3.fromRGB(255, 80, 80),
        Font = Enum.Font.GothamBold,
        TextSize = 14
    })
    CloseBtn.MouseButton1Click:Connect(function() Nevora:Unload() end)

    local MinBtn = Utility:Create("TextButton", {
        Name = "Minimize",
        Parent = self.Topbar,
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -70, 0.5, -15),
        BackgroundTransparency = 1,
        Text = "—",
        TextColor3 = Nevora.Theme.TextMuted,
        Font = Enum.Font.GothamBold,
        TextSize = 12
    })
    MinBtn.MouseButton1Click:Connect(function() self.MainFrame.Visible = false end)
    
    self.Sidebar = Utility:Create("Frame", {
        Name = "Sidebar",
        Parent = self.MainFrame,
        Size = UDim2.new(0, 160, 1, -40),
        Position = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = Nevora.Theme.Sidebar,
        BackgroundTransparency = 0.5
    })
    
    self.SidebarLayout = Utility:Create("ScrollingFrame", {
        Parent = self.Sidebar,
        Size = UDim2.new(1, 0, 1, -20),
        Position = UDim2.new(0, 0, 0, 10),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0
    })
    Utility:Create("UIListLayout", {
        Parent = self.SidebarLayout,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5),
        HorizontalAlignment = Enum.HorizontalAlignment.Center
    })
    
    self.ContentContainer = Utility:Create("Frame", {
        Name = "Content",
        Parent = self.MainFrame,
        Size = UDim2.new(1, -160, 1, -40),
        Position = UDim2.new(0, 160, 0, 40),
        BackgroundTransparency = 1
    })
    
    local toggleKey = config.ToggleKey or Enum.KeyCode.RightControl
    GlobalConnections:Add("UIToggle", UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == toggleKey then
            self.MainFrame.Visible = not self.MainFrame.Visible
        end
    end))
    
    return self
end

function Window:SelectTab(tabInstance)
    if self.CurrentTab then
        Utility:Tween(self.CurrentTab.TabButton, { BackgroundTransparency = 1, TextColor3 = Nevora.Theme.TextMuted })
        self.CurrentTab.Container.Visible = false
    end
    self.CurrentTab = tabInstance
    Utility:Tween(tabInstance.TabButton, { BackgroundTransparency = 0, TextColor3 = Nevora.Theme.Accent })
    tabInstance.Container.Visible = true
end

function Window:CreateTab(title, icon)
    local tab = Tab.new(self, title, icon)
    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    return tab
end

-- [ CONFIG ENGINE ]
Nevora.Config = {
    Path = "NevoraHub/Configs/",
    CurrentProfile = "default.json"
}

function Nevora.Config:Save(data)
    if writefile and makefolder then
        if not isfolder(self.Path) then makefolder(self.Path) end
        writefile(self.Path .. self.CurrentProfile, HttpService:JSONEncode(data))
    else
        warn("Nevora Hub: Environment doesn't support file saving system.")
    end
end

function Nevora.Config:Load()
    if isfile and readfile and isfile(self.Path .. self.CurrentProfile) then
        return HttpService:JSONDecode(readfile(self.Path .. self.CurrentProfile))
    end
    return {}
end

-- [ THEME MANAGER ]
function Nevora:SetTheme(newTheme)
    for key, value in pairs(newTheme) do
        Nevora.Theme[key] = value
    end
    Nevora.EventSystem:Fire("ThemeChanged", Nevora.Theme)
end

-- [ UNLOAD ENGINE ]
function Nevora:Unload()
    GlobalConnections:DisconnectAll()
    
    if Nevora.MainInstance then
        Nevora.MainInstance:Destroy()
        Nevora.MainInstance = nil
    end
    
    if TooltipGui then TooltipGui:Destroy() end
    if NotifContainer then NotifContainer:Destroy() end
    
    print("Nevora Hub: Framework unloaded and memory cleared.")
end

-- [ PUBLIC API ]
function Nevora:CreateWindow(config)
    return Window.new(config)
end

-- Export Library Globally
if getgenv then getgenv().Nevora = Nevora end

return Nevora
