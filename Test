        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = cbFrame,
    })

    clickArea.MouseButton1Click:Connect(toggle)

    cb.Instance = cbFrame
    cb.SetValue = function(_, checked)
        if cb.Checked ~= checked then
            toggle()
        end
    end

    table.insert(self.Components, cb)
    return cb
end

