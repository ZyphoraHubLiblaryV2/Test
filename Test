            displayLabel.Font = Enum.Font.GothamBold
            displayLabel.TextSize = 13
            displayLabel.TextXAlignment = Enum.TextXAlignment.Right

            local expandIcon = Instance.new("TextLabel")
            expandIcon.Parent = container
            expandIcon.Size = UDim2.new(0, 24, 1, 0)
            expandIcon.Position = UDim2.new(1, -28, 0, 0)
            expandIcon.BackgroundTransparency = 1
            expandIcon.Text = "▾"
            expandIcon.TextColor3 = Color3.fromRGB(150, 150, 180)
            expandIcon.TextSize = 16
            expandIcon.Font = Enum.Font.Gotham

            local expanded = false
            local optionsContainer = Instance.new("Frame")
            optionsContainer.Parent = container
            optionsContainer.BackgroundTransparency = 1
            optionsContainer.Size = UDim2.new(1, 0, 0, 0)
            optionsContainer.Position = UDim2.new(0, 0, 0, 38)
            optionsContainer.ClipsDescendants = true

            local optLayout = Instance.new("UIListLayout")
            optLayout.Parent = optionsContainer
            optLayout.Padding = UDim.new(0, 2)

            local obj = {
                Value = selected,
                Set = function(self, val)
                    if type(val) ~= "table" then val = {val} end
                    selected = val
                    self.Value = selected
                    local display = ""
                    for i, v in ipairs(selected) do
                        display = display .. v .. (i < #selected and ", " or "")
                    end
                    if display == "" then display = "None"
                    displayLabel.Text = display
                    pcall(callback, selected)
                    if flag then flags[flag] = selected end
                    if configEnabled then Window:SaveConfig() end
                end
            }

            for _, opt in pairs(options) do
                local optBtn = Instance.new("TextButton")
                optBtn.Parent = optionsContainer
                optBtn.Size = UDim2.new(1, 0, 0, 30)
                optBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                optBtn.Text = "  " .. tostring(opt)
                optBtn.TextColor3 = Color3.fromRGB(200, 200, 210)
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 13
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 4)

                local isSelected = false
                for _, s in ipairs(selected) do
                    if s == opt then isSelected = true end
                end
                if isSelected then
                    optBtn.BackgroundColor3 = Color3.fromRGB(50, 80, 180)
                    optBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                end

                optBtn.MouseButton1Click:Connect(function()
                    if not multi then selected = {} end
                    local found = false
                    for i, s in ipairs(selected) do
                        if s == opt then
                            table.remove(selected, i)
                            found = true
                            break
                        end
                    end
                    if not found then
                        if not multi then selected = {} end
                        table.insert(selected, opt)
                    end
                    obj:Set(selected)
                    
                    for _, child in pairs(optionsContainer:GetChildren()) do
                        if child:IsA("TextButton") then
                            local isSel = false
                            for _, s in ipairs(selected) do
                                if s == child.Text:gsub("^%s*(.-)%s*$", "%1") then isSel = true end
                            end
                            if isSel then
                                child.BackgroundColor3 = Color3.fromRGB(50, 80, 180)
                                child.TextColor3 = Color3.fromRGB(255, 255, 255)
                            else
                                child.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                                child.TextColor3 = Color3.fromRGB(200, 200, 210)
                            end
                        end
                    end
                    
                    if not multi then
                        expanded = false
                        TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                        TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, -12, 0, 38)}):Play()
                        expandIcon.Text = "▾"
                    end
                end)
            end

            container.MouseButton1Click:Connect(function()
                expanded = not expanded
                if expanded then
                    local totalHeight = #options * 32 + 12
                    TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, totalHeight)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, -12, 0, 38 + totalHeight)}):Play()
                    expandIcon.Text = "▴"
                else
                    TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                    TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, -12, 0, 38)}):Play()
                    expandIcon.Text = "▾"
                end
            end)

            if flag then flags[flag] = selected end
            elementObjects[flag] = obj
            return obj
        end

