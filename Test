            tipFrame.Visible = true
            tipFrame.Position = UDim2.new(0, tooltip.Target.AbsolutePosition.X, 0, tooltip.Target.AbsolutePosition.Y - 35)
            Utility.Tween(tipFrame, Constants.TweenInfo.Fast, {
