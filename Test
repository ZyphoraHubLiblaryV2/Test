    local button = CreateInstance("TextButton", {
        Name = config.Name,
        Parent = section.ItemsContainer,
        BackgroundColor3 = tab.Library.Accent,
        BorderSizePixel = 0,
        Font = Enum.Font.Gotham,
        Text = config.Name,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 13,
        Size = UDim2.new(1, 0, 0, 35),
