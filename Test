        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0.5, -6, 0.5, -6),
        BackgroundTransparency = 1,
        Image = IconSystem:GetIcon("Check"),
        ImageColor3 = Constants.Background,
        ImageTransparency = cb.Checked and 0 or 1,
        Parent = box,
    })

    local label = Utility.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, -30, 1, 0),
        Position = UDim2.new(0, 26, 0, 0),
        BackgroundTransparency = 1,
        Text = options.Text or "Checkbox",
        TextColor3 = Constants.TextPrimary,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = cbFrame,
    })

    local function toggle()
        cb.Checked = not cb.Checked

        Utility.Tween(box, Constants.TweenInfo.Fast, {
            BackgroundColor3 = cb.Checked and Constants.Accent or Constants.Secondary,
            BackgroundTransparency = cb.Checked and 0.2 or 0.5,
        })

        Utility.Tween(boxStroke, Constants.TweenInfo.Fast, {
            Color = cb.Checked and Constants.Accent or Constants.Border,
        })

        Utility.Tween(checkmark, Constants.TweenInfo.Fast, {
