                                TweenService:Create(optionsContainer, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                                TweenService:Create(container, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 36)}):Play()
                                expandIcon.Text = "▾"
                            end
