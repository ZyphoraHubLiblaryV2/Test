        -- ==========================================
        -- ELEMENT: SLIDER
        -- ==========================================
        function Elements:AddSlider(text, min, max, default, callback, flag, suffix)
            local current = default or min
            local sFrame = Instance.new("Frame", TabPage)
            sFrame.Size = UDim2.new(0, 400, 0, 50)
            sFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            Instance.new("UICorner", sFrame).CornerRadius = UDim.new(0, 5)
            
            local lbl = Instance.new("TextLabel", sFrame)
