Modules.Background = (function()
    local Bg = {}
    
    function Bg:ApplyGlobal(config, windowObj, theme)
        local targetFrame = windowObj and windowObj.MainFrame or (CoreGui:FindFirstChild("NevoraHubUI") and CoreGui.NevoraHubUI:FindFirstChild("MainWindow"))
        if not targetFrame then return end
        
        local oldBg = targetFrame:FindFirstChild("CustomBg")
        if oldBg then oldBg:Destroy() end
        
        if config.Type == "Image" then
            Modules.Utilities:CreateInstance("ImageLabel", targetFrame, "CustomBg", {
                Size = UDim2.new(1, 0, 1, 0),
                Image = config.Image,
                ImageTransparency = config.Transparency or 0,
                BackgroundTransparency = 1,
                ScaleType = Enum.ScaleType.Crop,
                ZIndex = 0
            })
        elseif config.Type == "Gradient" then
            Modules.Utilities:CreateInstance("UIGradient", targetFrame, "CustomBg", {
                Color = config.ColorSequence
            })
        end
    end
    
    return Bg
end)()

