    Text = "",
    TextColor3 = Nevora.Theme.Text,
    Font = Nevora.Theme.Font,
    TextSize = 12,
    AutomaticSize = Enum.AutomaticSize.XY
})

local currentTooltipConnection = nil
function Nevora.TooltipEngine:Add(instance, text)
    instance.MouseEnter:Connect(function()
        TooltipText.Text = text
        TooltipFrame.Visible = true
        
        if currentTooltipConnection then currentTooltipConnection:Disconnect() end
        currentTooltipConnection = RunService.RenderStepped:Connect(function()
            local mousePos = UserInputService:GetMouseLocation()
            TooltipFrame.Position = UDim2.new(0, mousePos.X + 15, 0, mousePos.Y - 20)
        end)
    end)
    
    instance.MouseLeave:Connect(function()
        TooltipFrame.Visible = false
        if currentTooltipConnection then
            currentTooltipConnection:Disconnect()
            currentTooltipConnection = nil
        end
    end)
end

function Utility:ApplyTooltip(instance, config)
    if config and config.Tooltip then
        Nevora.TooltipEngine:Add(instance, config.Tooltip)
    end
end

