Modules.Tabs = (function()
    local Tabs = {}
    Tabs.__index = Tabs
    
    function Tabs.new(name, iconId, windowObj)
        local self = setmetatable({}, Tabs)
        self.Window = windowObj
        self.MainLib = windowObj.MainLib
        self.Active = false
        
        local page = Modules.Utilities:CreateInstance("ScrollingFrame", windowObj.ContainerHolder, name .. "Page", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = self.MainLib.Theme.Border,
            CanvasSize = UDim2.new(0,0,0,0)
        })
        
        local pageLayout = Modules.Utilities:CreateInstance("UIListLayout", page, "Layout", {
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder
        })
        Modules.Utilities:CreateInstance("UIPadding", page, "Padding", {
            PaddingTop = UDim.new(0, 5), PaddingLeft = UDim.new(0, 5), PaddingRight = UDim.new(0, 5)
        })
        
        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 20)
        end)
        
        local tabBtn = Modules.Utilities:CreateInstance("TextButton", windowObj.TabContainer, name .. "TabBtn", {
            Size = UDim2.new(1, 0, 0, 42),
            BackgroundColor3 = self.MainLib.Theme.Secondary,
            BackgroundTransparency = 1,
            Text = "",
            BorderSizePixel = 0
        })
        Modules.Utilities:CreateInstance("UICorner", tabBtn, "Corner", { CornerRadius = UDim.new(0, 6) })
        
        local tabTitle = Modules.Utilities:CreateInstance("TextLabel", tabBtn, "Title", {
            Size = UDim2.new(1, -40, 1, 0),
            Position = UDim2.new(0, 35, 0, 0),
            Text = name,
            TextColor3 = self.MainLib.Theme.SecondaryText,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1
        })
        
        if iconId then
            self.Icon = Modules.Utilities:CreateInstance("ImageLabel", tabBtn, "Icon", {
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(0, 10, 0.5, -9),
                Image = iconId,
                BackgroundTransparency = 1,
                ImageColor3 = self.MainLib.Theme.SecondaryText
            })
        end
        
        tabBtn.MouseButton1Click:Connect(function() self:Select() end)
        
        self.PageFrame = page
        self.TabButton = tabBtn
        self.TitleLabel = tabTitle
        
        if #windowObj.Tabs == 0 then self:Select() end
        return self
    end
    
    function Tabs:Select()
        for _, t in ipairs(self.Window.Tabs) do
            if t.Active then
                t.Active = false
                t.PageFrame.Visible = false
                TweenService:Create(t.TabButton, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                TweenService:Create(t.TitleLabel, TweenInfo.new(0.2), {TextColor3 = self.MainLib.Theme.SecondaryText}):Play()
                if t.Icon then TweenService:Create(t.Icon, TweenInfo.new(0.2), {ImageColor3 = self.MainLib.Theme.SecondaryText}):Play() end
            end
        end
        
        self.Active = true
        self.PageFrame.Visible = true
        TweenService:Create(self.TabButton, TweenInfo.new(0.2), {BackgroundTransparency = 0, BackgroundColor3 = self.MainLib.Theme.Secondary}):Play()
        TweenService:Create(self.TitleLabel, TweenInfo.new(0.2), {TextColor3 = self.MainLib.Theme.Accent}):Play()
        if self.Icon then TweenService:Create(self.Icon, TweenInfo.new(0.2), {ImageColor3 = self.MainLib.Theme.Accent}):Play() end
    end
    
    function Tabs:SetBadge(text)
        local old = self.TabButton:FindFirstChild("Badge")
        if old then old:Destroy() end
        if not text then return end
        
        local badge = Modules.Utilities:CreateInstance("Frame", self.TabButton, "Badge", {
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(1, -25, 0.5, -9),
            BackgroundColor3 = self.MainLib.Theme.Accent,
            BorderSizePixel = 0
        })
        Modules.Utilities:CreateInstance("UICorner", badge, "Corner", { CornerRadius = UDim.new(1, 0) })
        Modules.Utilities:CreateInstance("TextLabel", badge, "Label", {
            Size = UDim2.new(1, 0, 1, 0),
            Text = text,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            Font = Enum.Font.GothamBold,
            TextSize = 10,
            BackgroundTransparency = 1
        })
    end
    
    function Tabs:CreateSection(title)
        return Modules.Elements.new(title, self.PageFrame, self.MainLib)
    end
    
    return Tabs
end)()

