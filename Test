            Size = UDim2.new(1, -70, 1, 0),
            Position = UDim2.new(0, 15, 0, 0),
            Text = text,
            TextColor3 = self.MainLib.Theme.Text,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1
        })
        
        local switch = Modules.Utilities:CreateInstance("TextButton", card, "Switch", {
            Size = UDim2.new(0, 44, 0, 24),
            Position = UDim2.new(1, -59, 0.5, -12),
            BackgroundColor3 = toggled and self.MainLib.Theme.Accent or self.MainLib.Theme.Secondary,
            Text = ""
        })
        Modules.Utilities:CreateInstance("UICorner", switch, "Corner", { CornerRadius = UDim.new(1, 0) })
        
        local node = Modules.Utilities:CreateInstance("Frame", switch, "Node", {
            Size = UDim2.new(0, 18, 0, 18),
            Position = toggled and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
