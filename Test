        })

        Utility.Tween(switchKnob, Constants.TweenInfo.Fast, {
            Position = toggle.Value and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10),
        })

        if toggle.Callback then
            toggle.Callback(toggle.Value)
