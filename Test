function NevoraHub.new(options)
    options = options or {}
    local self = setmetatable({}, NevoraHub)

    self.Name = options.Name or "NevoraHub"
    self.Version = "1.0.0"

    -- Initialize core systems
    self.Theme = ThemeEngine.new()
    self.Config = ConfigSystem.new(self.Name)
    self.Animation = AnimationEngine.new()

    -- Set initial theme
    if options.Theme then
        self.Theme:SetTheme(options.Theme)
    end

    -- Windows container
    self.Windows = {}
    self.Maid = Maid.new()

    -- Global notification container
    self.NotificationGui = Utility.Create("ScreenGui", {
        Name = self.Name .. "_Notifications",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
        Parent = CoreGui,
    })

    self.Notifications = NotificationSystem.new(self.NotificationGui)

    return self
end

function NevoraHub:CreateWindow(options)
    local window = Window.new(self, options)
    table.insert(self.Windows, window)
    return window
end

function NevoraHub:Notify(options)
    return self.Notifications:Notify(options)
end

function NevoraHub:Success(title, message, duration)
    return self.Notifications:Success(title, message, duration)
end

function NevoraHub:Error(title, message, duration)
    return self.Notifications:Error(title, message, duration)
end

function NevoraHub:Warning(title, message, duration)
    return self.Notifications:Warning(title, message, duration)
end

function NevoraHub:Info(title, message, duration)
    return self.Notifications:Info(title, message, duration)
end

function NevoraHub:SetTheme(themeName)
    self.Theme:SetTheme(themeName)
end

function NevoraHub:SaveConfig(name, data)
    return self.Config:SaveConfig(name, data)
end

function NevoraHub:LoadConfig(name)
    return self.Config:LoadConfig(name)
end

function NevoraHub:DeleteConfig(name)
    self.Config:DeleteConfig(name)
end

function NevoraHub:ExportConfig(name)
    return self.Config:ExportConfig(name)
end

function NevoraHub:ImportConfig(jsonString)
    return self.Config:ImportConfig(jsonString)
end

function NevoraHub:Destroy()
    self.Maid:Destroy()
    for _, window in ipairs(self.Windows) do
        window:Destroy()
    end
    self.Notifications:Destroy()
    self.NotificationGui:Destroy()
end

