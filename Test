    })
    
    self.Container = Utility:Create("ScrollingFrame", {
        Parent = self.Instance,
        Size = UDim2.new(1, -20, 0, 0),
        Position = UDim2.new(0, 10, 0, 45),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Nevora.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0)
    })
    
    self.ListLayout = Utility:Create("UIListLayout", {
        Parent = self.Container,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5)
    })
    
    local OptionButtons = {}
    
    local function UpdateCanvas()
        self.Container.CanvasSize = UDim2.new(0, 0, 0, self.ListLayout.AbsoluteContentSize.Y)
    end
    
    local function ToggleDropdown()
        self.IsOpen = not self.IsOpen
        local targetSize = self.IsOpen and UDim2.new(1, 0, 0, 45 + math.min(#self.Options * 30, 150) + 10) or UDim2.new(1, 0, 0, 45)
        local iconText = self.IsOpen and "-" or "+"
        
        Utility:Tween(self.Instance, { Size = targetSize }, 0.3, Enum.EasingStyle.Quint)
        Utility:Tween(self.Container, { Size = UDim2.new(1, -20, 0, math.min(#self.Options * 30, 150)) }, 0.3, Enum.EasingStyle.Quint)
        self.Icon.Text = iconText
        
        if self.IsOpen then
            Utility:Tween(self.Stroke, { Color = Nevora.Theme.Accent }, 0.3)
        else
            Utility:Tween(self.Stroke, { Color = Nevora.Theme.Border }, 0.3)
        end
    end
    
    self.MainButton.MouseButton1Click:Connect(ToggleDropdown)
    
    function self:Refresh(newOptions)
        self.Options = newOptions or {}
        for _, btn in pairs(OptionButtons) do btn:Destroy() end
        table.clear(OptionButtons)
        
        for i, option in ipairs(self.Options) do
            local optBtn = Utility:Create("TextButton", {
                Parent = self.Container,
                Size = UDim2.new(1, 0, 0, 25),
                BackgroundColor3 = Nevora.Theme.Background,
                Text = "  " .. option,
                TextColor3 = Nevora.Theme.TextMuted,
                Font = Nevora.Theme.Font,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false
            })
            Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = optBtn })
            
            optBtn.MouseEnter:Connect(function()
                Utility:Tween(optBtn, { BackgroundColor3 = Nevora.Theme.Hover, TextColor3 = Nevora.Theme.Text }, 0.2)
            end)
            optBtn.MouseLeave:Connect(function()
                if self.Selected ~= option then
                    Utility:Tween(optBtn, { BackgroundColor3 = Nevora.Theme.Background, TextColor3 = Nevora.Theme.TextMuted }, 0.2)
                end
            end)
            
            optBtn.MouseButton1Click:Connect(function()
                self.Selected = option
                self.SelectedLabel.Text = option
                self.Callback(option)
                ToggleDropdown()
                
                for _, btn in pairs(OptionButtons) do
                    Utility:Tween(btn, { BackgroundColor3 = Nevora.Theme.Background, TextColor3 = Nevora.Theme.TextMuted }, 0.2)
                end
                Utility:Tween(optBtn, { BackgroundColor3 = Nevora.Theme.Hover, TextColor3 = Nevora.Theme.Accent }, 0.2)
            end)
            
            table.insert(OptionButtons, optBtn)
        end
        UpdateCanvas()
    end
    
    self:Refresh(self.Options)
    
    return self
end

