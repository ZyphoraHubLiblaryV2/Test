function Tab:CreateColorPicker(config)
    config = config or {}
    local Theme = self.Hub.Theme
    local color = config.Default or Color3.fromRGB(255, 255, 255)
    local callback = config.Callback or function() end

    local Holder = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Theme.PanelLight,
        Parent = self.Page,
    })
    Utility.Corner(Holder, 8)

    Utility.Create("TextLabel", {
        Text = config.Name or "Color",
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.6, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })

    local Preview = Utility.Create("TextButton", {
        Text = "",
        BackgroundColor3 = color,
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -52, 0.5, -10),
        Parent = Holder,
    })
    Utility.Corner(Preview, 6)
    Utility.Stroke(Preview, Theme.Stroke, 1)

    -- Simple RGB slider popout
    local Popout = Utility.Create("Frame", {
        Size = UDim2.new(1, -20, 0, 0),
        Position = UDim2.new(0, 10, 0, 34),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Holder,
    })
    local popOpen = false

    local function makeChannel(labelText, order, initVal)
        local Row = Utility.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 20),
            Position = UDim2.new(0, 0, 0, order * 24),
            BackgroundTransparency = 1,
            Parent = Popout,
        })
        Utility.Create("TextLabel", {
            Text = labelText,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            TextColor3 = Theme.SubText,
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 20, 1, 0),
            Parent = Row,
        })
        local Bar = Utility.Create("Frame", {
            Size = UDim2.new(1, -30, 0, 6),
            Position = UDim2.new(0, 22, 0.5, -3),
            BackgroundColor3 = Theme.Stroke,
            Parent = Row,
        })
        Utility.Corner(Bar, 999)
        local Fill = Utility.Create("Frame", {
            Size = UDim2.new(initVal / 255, 0, 1, 0),
            BackgroundColor3 = Theme.Accent,
            Parent = Bar,
        })
        Utility.Corner(Fill, 999)
        return Bar, Fill
    end

    local r, g, b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
    local rBar, rFill = makeChannel("R", 0, r)
    local gBar, gFill = makeChannel("G", 1, g)
    local bBar, bFill = makeChannel("B", 2, b)

    local function updateColor()
        color = Color3.fromRGB(r, g, b)
        Preview.BackgroundColor3 = color
        local ok, err = pcall(callback, color)
        if not ok then warn("[Nevora Hub] ColorPicker callback error: " .. tostring(err)) end
    end

    local function bindChannel(bar, fill, setter)
        local dragging = false
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                setter(math.floor(rel * 255))
                updateColor()
            end
        end)
    end
    bindChannel(rBar, rFill, function(v) r = v end)
    bindChannel(gBar, gFill, function(v) g = v end)
    bindChannel(bBar, bFill, function(v) b = v end)

    Preview.MouseButton1Click:Connect(function()
        popOpen = not popOpen
        Utility.Tween(Popout, TweenInfo.new(0.2, EASE, DIR), {Size = UDim2.new(1, -20, 0, popOpen and 76 or 0)})
        Utility.Tween(Holder, TweenInfo.new(0.2, EASE, DIR), {Size = UDim2.new(1, 0, 0, popOpen and 118 or 34)})
    end)

    return {
        Set = function(newColor)
            color = newColor
            Preview.BackgroundColor3 = newColor
        end,
        Get = function() return color end,
    }
end

