-- ═══════════════════════════════════════════════════════════
-- THEME SWITCHER
-- ═══════════════════════════════════════════════════════════

function Nevora:SetTheme(themeName)
    if Themes[themeName] then
        self.Theme = Utility:DeepCopy(Themes[themeName])
    end
end

function Nevora:GetThemes()
    local themeNames = {}
    for name, _ in pairs(Themes) do
        table.insert(themeNames, name)
    end
    return themeNames
end

function Nevora:RegisterTheme(name, theme)
    Themes[name] = theme
end

