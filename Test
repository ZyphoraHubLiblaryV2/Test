                TextSize = 12,
                Font = i == #bc.Items and Enum.Font.GothamBold or Enum.Font.Gotham,
                AutomaticSize = Enum.AutomaticSize.X,
                Parent = bcFrame,
            })

            if i < #bc.Items then
                local separator = Utility.Create("ImageLabel", {
                    Name = "Separator" .. i,
                    Size = UDim2.new(0, 12, 0, 12),
                    Position = UDim2.new(0, 0, 0.5, -6),
                    BackgroundTransparency = 1,
                    Image = IconSystem:GetIcon("ChevronRight"),
                    ImageColor3 = Constants.TextSecondary,
                    Parent = bcFrame,
                })
            end
        end
    end

    build()

    bc.Instance = bcFrame
    bc.SetItems = function(_, items)
        bc.Items = items
        build()
    end

    return bc
end

