                if not gp and isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
                    obj:Set(input.KeyCode)
                    isBinding = false
                elseif not gp and not isBinding and input.KeyCode == key then
                    pcall(callback)
                end
