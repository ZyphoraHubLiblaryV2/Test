    -- Config System
    function Window:EnableConfig(fileName)
        configEnabled = true
        configFileName = fileName or "NevoraConfig"
        if not isfolder("NevoraHub") then makefolder("NevoraHub") end
        if not isfolder("NevoraHub/Configs") then makefolder("NevoraHub/Configs") end
    end

    function Window:SaveConfig()
        if not configEnabled then return end
        local data = {}
        for flag, value in pairs(flags) do
            data[flag] = value
        end
        local path = "NevoraHub/Configs/" .. configFileName .. ".json"
        if writefile then
            writefile(path, HttpService:JSONEncode(data))
        end
    end

    function Window:LoadConfig()
        if not configEnabled then return end
        local path = "NevoraHub/Configs/" .. configFileName .. ".json"
        if isfile and isfile(path) then
            local success, data = pcall(function()
                return HttpService:JSONDecode(readfile(path))
            end)
            if success and data then
                for flag, value in pairs(data) do
                    if flags[flag] and flags[flag].Set then
                        flags[flag]:Set(value)
                    end
                end
            end
        end
    end

    function Window:ModifyTheme(themeName)
        if Themes[themeName] then
            currentTheme = Themes[themeName]
            MainFrame.BackgroundColor3 = currentTheme.Background
            Topbar.BackgroundColor3 = currentTheme.Topbar
            TopbarCorner.BackgroundColor3 = currentTheme.Topbar
            Shadow.ImageColor3 = currentTheme.Shadow
            TitleLabel.TextColor3 = currentTheme.TextColor
            for _, btn in pairs(Topbar:GetChildren()) do
                if btn:IsA("TextButton") then
                    btn.TextColor3 = currentTheme.TextColor
                end
            end
            Sidebar.BackgroundColor3 = currentTheme.Background
            MainContent.BackgroundColor3 = currentTheme.Background
            NevoraHub:Notify({Title = "Theme Changed", Content = "Changed to " .. themeName, Duration = 2})
        end
    end

