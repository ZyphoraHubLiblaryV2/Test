function Section:CreateRadio(options)
    options = options or {}
    local radio = {}
    radio.Options = options.Options or {}
    radio.Selected = options.Default or 1
    radio.Callback = options.Callback
    radio.Buttons = {}

    local radioFrame = Utility.Create("Frame", {
        Name = options.Name or "Radio",
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = self.ComponentContainer,
    })

    local layout = Utility.Create("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = radioFrame,
    })

    if options.Text then
        local label = Utility.Create("TextLabel", {
            Name = "Label",
            Size = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1,
            Text = options.Text,
            TextColor3 = Constants.TextPrimary,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = radioFrame,
        })
    end

    local function selectOption(index)
        radio.Selected = index
        for i, btn in ipairs(radio.Buttons) do
            local isSelected = i == index
            Utility.Tween(btn.Circle, Constants.TweenInfo.Fast, {
                BackgroundColor3 = isSelected and Constants.Accent or Constants.Border,
            })
            Utility.Tween(btn.Dot, Constants.TweenInfo.Fast, {
                BackgroundTransparency = isSelected and 0 or 1,
            })
        end
        if radio.Callback then
            radio.Callback(radio.Options[index])
        end
    end

    for i, opt in ipairs(radio.Options) do
        local optFrame = Utility.Create("Frame", {
            Name = "Option" .. i,
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundTransparency = 1,
            Parent = radioFrame,
        })

        local circle = Utility.Create("Frame", {
            Name = "Circle",
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(0, 0, 0.5, -9),
            BackgroundColor3 = i == radio.Selected and Constants.Accent or Constants.Border,
            BorderSizePixel = 0,
            Parent = optFrame,
        })

        local circleCorner = Utility.Create("UICorner", {
            CornerRadius = UDim.new(1, 0),
            Parent = circle,
        })

        local circleStroke = Utility.Create("UIStroke", {
            Color = Constants.Border,
            Thickness = 2,
            Parent = circle,
        })

        local dot = Utility.Create("Frame", {
            Name = "Dot",
            Size = UDim2.new(0, 8, 0, 8),
            Position = UDim2.new(0.5, -4, 0.5, -4),
            BackgroundColor3 = Constants.TextPrimary,
            BackgroundTransparency = i == radio.Selected and 0 or 1,
            BorderSizePixel = 0,
            Parent = circle,
        })

        local dotCorner = Utility.Create("UICorner", {
            CornerRadius = UDim.new(1, 0),
            Parent = dot,
        })

        local optLabel = Utility.Create("TextLabel", {
            Name = "Label",
            Size = UDim2.new(1, -30, 1, 0),
            Position = UDim2.new(0, 26, 0, 0),
            BackgroundTransparency = 1,
            Text = opt.Label or tostring(opt),
            TextColor3 = Constants.TextPrimary,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = optFrame,
        })

        local clickArea = Utility.Create("TextButton", {
            Name = "ClickArea",
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = optFrame,
        })

        clickArea.MouseButton1Click:Connect(function()
            selectOption(i)
        end)

        table.insert(radio.Buttons, {
            Circle = circle,
            Dot = dot,
        })
    end

    radio.Instance = radioFrame
    radio.SetValue = function(_, index)
        selectOption(index)
    end

    table.insert(self.Components, radio)
    return radio
end

