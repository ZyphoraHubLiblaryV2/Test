function Window:Minimize()
    self.Signals.WindowMinimized:Fire()
    Utility:Tween(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
        Size = UDim2.new(0, self.MainFrame.AbsoluteSize.X, 0, 50),
    })
end

function Window:Maximize()
    self.Signals.WindowMaximized:Fire()
    Utility:Tween(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
        Size = self.Size,
    })
end

function Window:Close()
    self.Signals.WindowClosed:Fire()
    Utility:Tween(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1,
    }, function()
        self.MainFrame:Destroy()
        self.Maid:Destroy()
    end)
end

function Window:SetTheme(themeName)
    if Themes[themeName] then
        self.Theme = Utility:DeepCopy(Themes[themeName])
    end
end

function Window:Notify(config)
    return self.Notifications:Notify(config)
end

