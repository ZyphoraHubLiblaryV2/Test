        BackgroundTransparency = 1,
        Text = options.Text or "Number",
        TextColor3 = Constants.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = niFrame,
    })

    local inputFrame = Utility.Create("Frame", {
        Name = "InputFrame",
        Size = UDim2.new(1, 0, 0, 36),
        Position = UDim2.new(0, 0, 0, 22),
        BackgroundColor3 = Constants.Secondary,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Parent = niFrame,
    })

    local frameCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = inputFrame,
    })

    local frameStroke = Utility.Create("UIStroke", {
        Color = Constants.Border,
        Thickness = 1,
        Transparency = 0.5,
        Parent = inputFrame,
    })

    local textInput = Utility.Create("TextBox", {
        Name = "Input",
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(ni.Value),
        PlaceholderText = tostring(ni.Min),
        PlaceholderColor3 = Constants.TextSecondary,
        TextColor3 = Constants.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        Parent = inputFrame,
    })

    local incBtn = Utility.Create("TextButton", {
        Name = "Increment",
        Size = UDim2.new(0, 28, 0, 28),
        Position = UDim2.new(1, -60, 0.5, -14),
        BackgroundColor3 = Constants.Accent,
        BackgroundTransparency = 0.2,
        Text = "+",
        TextColor3 = Constants.Background,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        Parent = inputFrame,
    })

    local incCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = incBtn,
    })

    local decBtn = Utility.Create("TextButton", {
        Name = "Decrement",
        Size = UDim2.new(0, 28, 0, 28),
        Position = UDim2.new(1, -30, 0.5, -14),
        BackgroundColor3 = Constants.Border,
        BackgroundTransparency = 0.5,
        Text = "−",
        TextColor3 = Constants.TextPrimary,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        Parent = inputFrame,
    })

    local decCorner = Utility.Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = decBtn,
    })

    local function updateValue(newValue)
        newValue = math.clamp(newValue, ni.Min, ni.Max)
        if ni.Decimals > 0 then
            newValue = math.floor(newValue * (10 ^ ni.Decimals)) / (10 ^ ni.Decimals)
        else
            newValue = math.floor(newValue)
        end
        ni.Value = newValue
        textInput.Text = tostring(newValue)
        if ni.Callback then
            ni.Callback(newValue)
        end
    end

    textInput.Focused:Connect(function()
        Utility.Tween(frameStroke, Constants.TweenInfo.Fast, {
            Color = Constants.Accent,
            Transparency = 0.3,
        })
    end)

    textInput.FocusLost:Connect(function()
        Utility.Tween(frameStroke, Constants.TweenInfo.Fast, {
            Color = Constants.Border,
            Transparency = 0.5,
        })

        local num = tonumber(textInput.Text)
        if num then
            updateValue(num)
        else
            textInput.Text = tostring(ni.Value)
        end
    end)

    incBtn.MouseButton1Click:Connect(function()
        updateValue(ni.Value + (options.Step or 1))
    end)

    decBtn.MouseButton1Click:Connect(function()
        updateValue(ni.Value - (options.Step or 1))
    end)

    ni.Instance = niFrame
    ni.SetValue = function(_, value)
        updateValue(value)
    end
    ni.GetValue = function()
        return ni.Value
    end

    table.insert(self.Components, ni)
    return ni
end

