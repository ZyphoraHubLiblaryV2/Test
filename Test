            Parent = self.Main
        })

        local resizing = false
        resizeHandle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
                local newSize = UDim2.new(0, 
                    math.max(self.MinSize.X, input.Position.X - self.Main.AbsolutePosition.X),
                    0,
                    math.max(self.MinSize.Y, input.Position.Y - self.Main.AbsolutePosition.Y)
                )
                self.Main.Size = newSize
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = false
            end
        end)
    end

    -- Toggle key
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == self.ToggleKey then
            self:Toggle()
        end
    end)

    -- Open animation
    task.spawn(function()
        task.wait(0.1)
        self.Main.Size = UDim2.new(0, self.Size.X.Offset, 0, 0)
        Tween(self.Main, 0.5, {
            Size = self.Size
        }, Enum.EasingStyle.Quint):Play()
    end)

    -- Notification System
    self.Notifications = NotificationSystem:Init(self.ScreenGui)

    return self
end

function Window:Toggle()
    self.Main.Visible = not self.Main.Visible
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Tween(self.Main, 0.3, {Size = UDim2.new(0, self.Main.Size.X.Offset, 0, 50)}):Play()
    else
        Tween(self.Main, 0.3, {Size = self.Size}):Play()
    end
end

function Window:Notify(config)
    self.Notifications:Notify(config)
end

